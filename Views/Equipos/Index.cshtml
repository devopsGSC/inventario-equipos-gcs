@model List<Equipo>
@{ ViewData["Title"] = "Equipos"; }

<div class="page-header">
  <div class="page-title">
    Equipos
    @if (!string.IsNullOrEmpty(ViewBag.Estado as string))
    { <span class="badge badge-bodega" style="font-size:13px;margin-left:8px">@ViewBag.Estado</span> }
  </div>
  @if (await PermisoSvc.TienePermiso(User, "equipos.crear"))
  {
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Registrar equipo</a>
  }
</div>

@{
  bool enModoSeleccion = ViewBag.ParaEmpleado != null || ViewBag.ParaMiembroExterno != null || ViewBag.ParaGrupo != null;
}

@if (enModoSeleccion)
{
  <div class="card" style="margin-bottom:16px;background:var(--blue-bg)">
    <div class="card-body" style="padding:12px 20px;display:flex;align-items:center;justify-content:space-between">
      <div style="font-size:13.5px">
        <i class="bi bi-person-check"></i>
        Seleccionando equipo para asignar a <strong>@ViewBag.NombreDestino</strong>
      </div>
      <a asp-controller="@ViewBag.ControladorDestino" asp-action="Details"
         asp-route-id="@(ViewBag.ParaEmpleado ?? ViewBag.ParaMiembroExterno ?? ViewBag.ParaGrupo)"
         class="btn btn-secondary btn-sm">Cancelar</a>
    </div>
  </div>
}

<div class="card" style="margin-bottom:16px">
  <div class="card-body" style="padding:14px 20px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
      <input type="hidden" name="estado" value="@ViewBag.Estado"/>
      @if (ViewBag.ParaEmpleado != null)
      {
        <input type="hidden" name="paraEmpleado" value="@ViewBag.ParaEmpleado"/>
      }
      else if (ViewBag.ParaMiembroExterno != null)
      {
        <input type="hidden" name="paraMiembroExterno" value="@ViewBag.ParaMiembroExterno"/>
      }
      else if (ViewBag.ParaGrupo != null)
      {
        <input type="hidden" name="paraGrupo" value="@ViewBag.ParaGrupo"/>
      }

      <div class="search-box" style="flex:1;min-width:200px">
        <i class="bi bi-search"></i>
        <input type="text" name="buscar" class="form-control"
               placeholder="Buscar por nombre, serie o marca..." value="@ViewBag.Buscar"/>
      </div>

      <select name="tipo" class="form-control" style="width:160px">
        <option value="">Todos los tipos</option>
        @foreach (var t in ViewBag.Tipos as List<string> ?? [])
        {
          <option value="@t" selected="@(ViewBag.Tipo == t ? "selected" : null)">@t</option>
        }
      </select>

      <button type="submit" class="btn btn-secondary">Filtrar</button>
      @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) ||
           !string.IsNullOrEmpty(ViewBag.Estado as string) ||
           !string.IsNullOrEmpty(ViewBag.Tipo as string))
      {
        <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
      }
    </form>
  </div>
</div>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Equipo</th><th>Tipo</th><th>No. Serie</th><th>Estado</th><th>Garantía</th><th>Registrado</th><th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var e in Model)
        {
          var garantiaVence = e.FechaGarantia.HasValue &&
              e.FechaGarantia.Value <= DateTime.Today.AddDays(30) &&
              e.FechaGarantia.Value >= DateTime.Today;
          var garantiaVencida = e.FechaGarantia.HasValue &&
              e.FechaGarantia.Value < DateTime.Today &&
              e.Estado != "Baja";
          <tr>
            <td>
              <div style="font-weight:500">@e.NombreEquipo</div>
              <div class="text-muted">@e.Marca — @e.Modelo</div>
            </td>
            <td>@e.TipoEquipo?.Nombre</td>
            <td class="mono">@e.NumeroSerie
              @if (!string.IsNullOrEmpty(e.IMEI))
              { <div style="font-size:11px;color:var(--dark-text2)">IMEI: @e.IMEI</div> }
            </td>
            <td><partial name="_EstadoBadge" model="@e.Estado" /></td>
            <td>
              @if (garantiaVencida)
              {
                <span class="badge badge-baja">Vencida — @e.FechaGarantia!.Value.ToString("dd/MM/yyyy")</span>
              }
              else if (e.FechaGarantia.HasValue)
              {
                <span class="@(garantiaVence ? "badge badge-garantia" : "text-muted")">
                  @(garantiaVence ? "⚠ " : "")@e.FechaGarantia.Value.ToString("dd/MM/yyyy")
                </span>
              }
              else { <span class="text-muted">—</span> }
            </td>
            <td class="text-muted" style="font-size:12px">@e.FechaRegistro.ToString("dd/MM/yyyy")</td>
            <td>
              <div class="gap-2">
                @if (enModoSeleccion && e.Estado == "Bodega" &&
                     (await PermisoSvc.TienePermiso(User, "movimientos.asignar") || await PermisoSvc.TienePermiso(User, "movimientos.prestamo")))
                {
                  <a asp-controller="Movimientos" asp-action="Registrar" asp-route-equipoId="@e.Id"
                     asp-route-empleadoId="@ViewBag.ParaEmpleado" asp-route-miembroExternoId="@ViewBag.ParaMiembroExterno" asp-route-grupoId="@ViewBag.ParaGrupo"
                     class="btn btn-primary btn-sm">
                    <i class="bi bi-box-arrow-right"></i> Asignar
                  </a>
                }
                <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-secondary btn-sm"><i class="bi bi-eye"></i></a>
                @if (await PermisoSvc.TienePermiso(User, "equipos.editar"))
                {
                  <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                }
              </div>
            </td>
          </tr>
        }
        @if (!Model.Any())
        {
          <tr><td colspan="7">
            <div class="empty-state"><i class="bi bi-inbox"></i>No hay equipos que mostrar.</div>
          </td></tr>
        }
      </tbody>
    </table>
  </div>
  <partial name="_Paginacion" model="ViewBag.Paginacion as InventarioTI.ViewModels.PaginacionViewModel"/>
</div>
