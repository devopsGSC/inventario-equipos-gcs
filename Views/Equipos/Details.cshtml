@model EquipoDetalleViewModel
@{ ViewData["Title"] = Model.Equipo.NombreEquipo; var eq = Model.Equipo; }

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Equipos</a>
    <div class="page-title" style="margin-top:4px">@eq.NombreEquipo</div>
  </div>
  <div class="gap-2">
    @if (eq.Estado != "Baja" && (await PermisoSvc.TienePermiso(User, "movimientos.asignar") ||
                                  await PermisoSvc.TienePermiso(User, "movimientos.prestamo") ||
                                  await PermisoSvc.TienePermiso(User, "movimientos.garantia")))
    {
      <a asp-controller="Movimientos" asp-action="Registrar" asp-route-equipoId="@eq.Id" class="btn btn-primary"><i class="bi bi-arrow-left-right"></i> Registrar movimiento</a>
    }
    @if (await PermisoSvc.TienePermiso(User, "equipos.editar"))
    {
      <a asp-action="Edit" asp-route-id="@eq.Id" class="btn btn-secondary"><i class="bi bi-pencil"></i> Editar</a>
    }
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Información del equipo</div>
      <partial name="_EstadoBadge" model="@eq.Estado" />
    </div>
    <div class="card-body">
      <div class="form-grid" style="gap:14px 20px">
        <div>
          <div class="form-label">Tipo</div>
          <div style="font-size:14px;font-weight:500">@(eq.TipoEquipo?.Nombre ?? "—")</div>
        </div>
        <div>
          <div class="form-label">Marca / Modelo</div>
          <div style="font-size:14px;font-weight:500">@eq.Marca @eq.Modelo</div>
        </div>
        <div>
          <div class="form-label">Número de serie</div>
          <div style="font-size:14px;font-weight:500;font-family:'DM Mono',monospace">@eq.NumeroSerie</div>
        </div>
        @if (!string.IsNullOrEmpty(eq.IMEI))
        {
          <div>
            <div class="form-label">IMEI</div>
            <div style="font-size:14px;font-weight:500;font-family:'DM Mono',monospace">@eq.IMEI</div>
          </div>
        }
        <div>
          <div class="form-label">Costo</div>
          <div style="font-size:14px;font-weight:500">@(eq.Costo.HasValue ? "$" + eq.Costo.Value.ToString("N2") : "—")</div>
        </div>
        <div>
          <div class="form-label">Fecha de compra</div>
          <div style="font-size:14px;font-weight:500">@(eq.FechaCompra?.ToString("dd/MM/yyyy") ?? "—")</div>
        </div>
        <div>
          <div class="form-label">Fecha de registro en sistema</div>
          <div style="font-size:14px;font-weight:500">@eq.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div>
          <div class="form-label">Garantía hasta</div>
          <div style="font-size:14px;font-weight:500">@(eq.FechaGarantia?.ToString("dd/MM/yyyy") ?? "—")</div>
        </div>
        @if (!string.IsNullOrEmpty(eq.Accesorios))
        {
          <div style="grid-column:span 2">
            <div class="form-label">Accesorios</div>
            <div style="font-size:14px">@eq.Accesorios</div>
          </div>
        }
      </div>
      @if (!string.IsNullOrEmpty(eq.RAM) || !string.IsNullOrEmpty(eq.Procesador) || !string.IsNullOrEmpty(eq.Almacenamiento) || eq.PlanData != null)
      {
        <div style="border-top:1px solid #f0f3f8;padding-top:12px;margin-top:14px">
          <div class="form-label" style="margin-bottom:8px">Especificaciones técnicas</div>
          <div class="form-grid" style="gap:14px 20px">
            @if (!string.IsNullOrEmpty(eq.RAM))
            {
              <div>
                <div class="form-label">RAM</div>
                <div style="font-size:14px;font-weight:500">@eq.RAM</div>
              </div>
            }
            @if (!string.IsNullOrEmpty(eq.Procesador))
            {
              <div>
                <div class="form-label">Procesador</div>
                <div style="font-size:14px;font-weight:500">@eq.Procesador</div>
              </div>
            }
            @if (!string.IsNullOrEmpty(eq.Almacenamiento))
            {
              <div>
                <div class="form-label">Almacenamiento</div>
                <div style="font-size:14px;font-weight:500">@eq.Almacenamiento</div>
              </div>
            }
            @if (eq.PlanData != null)
            {
              <div>
                <div class="form-label">Plan de datos</div>
                <div style="font-size:14px;font-weight:500"><i class="bi bi-sim"></i> @eq.PlanData.Nombre</div>
              </div>
            }
          </div>
        </div>
      }
      @if (eq.FechaGarantia.HasValue && eq.FechaGarantia.Value <= DateTime.Today.AddDays(30) && eq.FechaGarantia.Value >= DateTime.Today)
      {
        <div class="alert alert-warning" style="margin-top:16px;margin-bottom:0">
          <i class="bi bi-exclamation-triangle-fill"></i>
          Garantía vence en @((eq.FechaGarantia.Value - DateTime.Today).Days) días.
        </div>
      }
    </div>
    @if (await PermisoSvc.TienePermiso(User, "equipos.baja") && eq.Estado == "Bodega")
    {
      <div class="card-body" style="border-top:1px solid #f0f3f8;padding-top:14px">
        <form asp-action="Dar_De_Baja" asp-route-id="@eq.Id" method="post" onsubmit="return confirmarSubmit(event, '¿Dar de baja este equipo?')">
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-x-circle"></i> Dar de baja</button>
        </form>
      </div>
    }
    @if (await PermisoSvc.TienePermiso(User, "equipos.baja") && eq.Estado == "Baja")
    {
      <div class="card-body" style="border-top:1px solid #f0f3f8;padding-top:14px">
        <div class="alert alert-warning" style="margin-bottom:12px;font-size:12.5px">
          <i class="bi bi-info-circle-fill"></i> Este equipo está dado de baja. Puedes reactivarlo para que vuelva a estar disponible en bodega.
        </div>
        <form asp-action="Reactivar" asp-route-id="@eq.Id" method="post" onsubmit="return confirmarSubmit(event, '¿Reactivar este equipo? Volverá al estado Bodega.')">
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-arrow-counterclockwise"></i> Reactivar equipo</button>
        </form>
      </div>
    }
  </div>

  <div class="card">
    <div class="card-header"><div class="card-title">Responsable actual</div></div>
    <div class="card-body">
      @if (Model.MovimientoActivo != null && (Model.MovimientoActivo.Empleado != null || Model.MovimientoActivo.MiembroExterno != null || Model.MovimientoActivo.Grupo != null))
      {
        var emp     = Model.MovimientoActivo.Empleado;
        var miembro = Model.MovimientoActivo.MiembroExterno;
        var grupo   = Model.MovimientoActivo.Grupo;
        var mov = Model.MovimientoActivo;
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
          <div style="width:46px;height:46px;border-radius:50%;background:var(--blue-bg);color:var(--blue-text);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">
            <i class="bi bi-person-fill"></i>
          </div>
          <div>
            <div style="font-weight:600;font-size:15px">@mov.NombreResponsable</div>
            <div class="text-muted">@(emp != null ? $"{emp.CodigoEmpleado} — {emp.Cargo}" : miembro?.Organizacion)</div>
          </div>
        </div>
        <div class="form-grid" style="gap:10px">
          <div>
            <div class="form-label">@(emp != null ? "Departamento" : miembro != null ? "Organización" : "Descripción")</div>
            <div>@(emp?.Departamento?.Nombre ?? miembro?.Organizacion ?? grupo?.Descripcion ?? "—")</div>
          </div>
          @if (emp != null)
          {
            <div>
              <div class="form-label">DUI</div>
              <div>@emp.DUI</div>
            </div>
          }
          else if (miembro?.Identificacion != null)
          {
            <div>
              <div class="form-label">Identificación</div>
              <div>@miembro.Identificacion</div>
            </div>
          }
          <div>
            <div class="form-label">Tipo de movimiento</div>
            <div>@mov.TipoMovimiento</div>
          </div>
          <div>
            <div class="form-label">Desde</div>
            <div>@mov.FechaInicio.ToString("dd/MM/yyyy")</div>
          </div>
          @if (mov.FechaFinEstimada.HasValue)
          {
            <div>
              <div class="form-label">Devolución estimada</div>
              <div>@mov.FechaFinEstimada.Value.ToString("dd/MM/yyyy")</div>
            </div>
          }
          @if (mov.Sitio != null)
          {
            <div>
              <div class="form-label">Sitio / Ubicación</div>
              <div><i class="bi bi-geo-alt"></i> @mov.Sitio.Nombre</div>
            </div>
          }
        </div>
        <div style="margin-top:16px">
          <a asp-controller="Movimientos" asp-action="Carta" asp-route-id="@mov.Id" class="btn btn-success btn-sm">
            <i class="bi bi-file-earmark-pdf"></i> Carta de compromiso
          </a>
        </div>
      }
      else
      {
        <div class="empty-state" style="padding:30px 0">
          <i class="bi bi-person-dash"></i>
          <p>Este equipo no está asignado a ningún responsable actualmente.</p>
        </div>
      }
    </div>
  </div>
</div>

<div class="card" style="margin-bottom:24px">
  <div class="card-header">
    <div class="card-title">Periféricos adjuntos</div>
    <div style="display:flex;align-items:center;gap:8px">
      @{ var perifs = ViewBag.PerifeicosActivos as List<EquipoPeriferico> ?? new List<EquipoPeriferico>(); }
      <span class="badge badge-asignado">@perifs.Count</span>
      @if (await PermisoSvc.TienePermiso(User, "equipos.editar") && (eq.Estado == "Asignado" || eq.Estado == "Prestamo"))
      {
        <button type="button" class="btn btn-secondary btn-sm" onclick="abrirModalPerif()">
          <i class="bi bi-plus"></i> Adjuntar periférico
        </button>
      }
    </div>
  </div>
  @if (perifs.Any())
  {
    <div class="table-wrap">
      <table>
        <thead><tr><th>Tipo</th><th>Marca / Modelo</th><th>No. Serie</th><th>Desde</th></tr></thead>
        <tbody>
          @foreach (var ep in perifs)
          {
            <tr>
              <td>@ep.Periferico?.TipoPeriferico?.Nombre</td>
              <td><a asp-controller="Perifericos" asp-action="Details" asp-route-id="@ep.PerifericoId" style="color:var(--accent);text-decoration:none;font-weight:500">@ep.Periferico?.Marca @ep.Periferico?.Modelo</a></td>
              <td class="mono">@ep.Periferico?.NumeroSerie</td>
              <td class="text-muted">@ep.FechaAsignacion.ToString("dd/MM/yyyy")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
  else
  {
    <div class="card-body"><div class="empty-state" style="padding:16px"><i class="bi bi-display"></i>Sin periféricos adjuntos.</div></div>
  }
</div>

<div class="card" style="margin-bottom:24px">
  <div class="card-header">
    <div class="card-title">Licencias adjuntas</div>
    @{ var licenciasEq = ViewBag.LicenciasActuales as List<LicenciaAsignacion> ?? new List<LicenciaAsignacion>(); }
    <span class="badge badge-asignado">@licenciasEq.Count</span>
  </div>
  @if (licenciasEq.Any())
  {
    <div class="table-wrap">
      <table>
        <thead><tr><th>Licencia</th><th>Desde</th></tr></thead>
        <tbody>
          @foreach (var la in licenciasEq)
          {
            <tr>
              <td><a asp-controller="Licencias" asp-action="Details" asp-route-id="@la.TipoLicenciaId" style="color:var(--accent);text-decoration:none;font-weight:500">@la.TipoLicencia?.Nombre</a></td>
              <td class="text-muted">@la.FechaAsignacion.ToString("dd/MM/yyyy")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
  else
  {
    <div class="card-body"><div class="empty-state" style="padding:16px"><i class="bi bi-card-checklist"></i>Sin licencias adjuntas.</div></div>
  }
</div>

<!-- Modal adjuntar periférico -->
<div id="perifModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1000;align-items:center;justify-content:center">
  <div style="background:var(--surface);border-radius:12px;padding:24px;width:500px;max-height:70vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.18)">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <div style="font-size:15px;font-weight:600">Adjuntar periférico</div>
      <button type="button" onclick="cerrarModalPerif()" style="background:none;border:none;font-size:22px;cursor:pointer;color:var(--dark-text2)">×</button>
    </div>
    <input type="text" id="buscarPerif" class="form-control" placeholder="Buscar por tipo, marca o serie..."
           oninput="filtrarPerif()" style="margin-bottom:12px"/>
    <div id="perifOpciones" style="display:flex;flex-direction:column;gap:6px"></div>
  </div>
</div>

<script>
let todosPerifs = [];

async function abrirModalPerif() {
  document.getElementById('perifModal').style.display = 'flex';
  if (!todosPerifs.length) {
    try {
      const res = await fetch('/Perifericos/Disponibles');
      todosPerifs = await res.json();
    } catch(e) {
      document.getElementById('perifOpciones').innerHTML = '<div class="text-muted" style="padding:10px">Error cargando periféricos.</div>';
      return;
    }
  }
  renderOpciones(todosPerifs);
}
function cerrarModalPerif() {
  document.getElementById('perifModal').style.display = 'none';
  document.getElementById('buscarPerif').value = '';
}
function filtrarPerif() {
  const q = document.getElementById('buscarPerif').value.toLowerCase();
  renderOpciones(todosPerifs.filter(p =>
    (p.marca||'').toLowerCase().includes(q) ||
    (p.modelo||'').toLowerCase().includes(q) ||
    (p.numeroSerie||'').toLowerCase().includes(q) ||
    (p.tipo||'').toLowerCase().includes(q)));
}
function renderOpciones(lista) {
  const cont = document.getElementById('perifOpciones');
  cont.innerHTML = '';
  if (!lista.length) {
    cont.innerHTML = '<div class="text-muted" style="font-size:13px;padding:10px">No hay periféricos disponibles en stock.</div>';
    return;
  }
  lista.forEach(p => {
    const div = document.createElement('div');
    div.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border:1px solid #dde2ec;border-radius:8px;margin-bottom:4px';
    div.innerHTML = `
      <div>
        <div style="font-weight:500;font-size:13.5px">${p.tipo} — ${p.marca} ${p.modelo}</div>
        <div style="font-size:11.5px;color:var(--dark-text2);font-family:monospace">${p.numeroSerie}</div>
      </div>
      <button type="button" class="btn btn-primary btn-sm" onclick="adjuntarPerif(${p.id})">Adjuntar</button>`;
    cont.appendChild(div);
  });
}
async function adjuntarPerif(perifId) {
  try {
    const res = await fetch('/Equipos/AdjuntarPeriferico', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ equipoId: @eq.Id, perifericoId: perifId })
    });
    if (res.ok) {
      cerrarModalPerif();
      location.reload();
    } else {
      const msg = await res.text();
      alert('No se pudo adjuntar: ' + msg);
    }
  } catch(e) {
    alert('Error de conexión.');
  }
}
</script>
  <div class="card-body">
    @if (!Model.Historial.Any())
    {
      <div class="empty-state"><i class="bi bi-clock-history"></i>Sin movimientos registrados.</div>
    }
    else
    {
      <ul class="timeline">
        @foreach (var m in Model.Historial)
        {
          var dotBg    = m.TipoMovimiento switch { "Asignacion"=>"var(--blue-bg)","Prestamo"=>"var(--purple-bg)","Devolucion"=>"var(--green-bg)","EntradaGarantia"=>"var(--amber-bg)","SalidaGarantia"=>"var(--green-bg)","Baja"=>"var(--red-bg)","Reactivacion"=>"var(--green-bg)",_=>"var(--gray-bg)" };
          var dotColor = m.TipoMovimiento switch { "Asignacion"=>"var(--blue-text)","Prestamo"=>"var(--purple-text)","Devolucion"=>"var(--green-text)","EntradaGarantia"=>"var(--amber-text)","SalidaGarantia"=>"var(--green-text)","Baja"=>"var(--red-text)","Reactivacion"=>"var(--green-text)",_=>"var(--gray-text)" };
          var icon     = m.TipoMovimiento switch { "Asignacion"=>"bi-person-check-fill","Prestamo"=>"bi-arrow-left-right","Devolucion"=>"bi-arrow-return-left","EntradaGarantia"=>"bi-shield-check","SalidaGarantia"=>"bi-shield-x","Baja"=>"bi-x-circle-fill","Reactivacion"=>"bi-arrow-counterclockwise",_=>"bi-circle" };
          <li class="timeline-item">
            <div class="timeline-dot" style="background:@dotBg;color:@dotColor"><i class="bi @icon"></i></div>
            <div class="timeline-body">
              <div class="timeline-title">@m.TipoMovimiento
                @if (m.CartaGenerada) { <span class="badge badge-green" style="font-size:10px;margin-left:6px"><i class="bi bi-file-earmark-check"></i> Carta generada</span> }
              </div>
              <div class="timeline-meta">
                @m.FechaInicio.ToString("dd/MM/yyyy HH:mm")
                @if (m.Empleado != null || m.MiembroExterno != null || m.Grupo != null) { <span> — @m.NombreResponsable@(m.Empleado != null ? $" ({m.Empleado.CodigoEmpleado})" : "")</span> }
                @if (m.Sitio != null) { <span> — <i class="bi bi-geo-alt"></i> @m.Sitio.Nombre</span> }
                @if (m.FechaDevolucion.HasValue) { <span> — Devuelto: @m.FechaDevolucion.Value.ToString("dd/MM/yyyy")</span> }
                @if (!string.IsNullOrEmpty(m.Observaciones)) { <div>@m.Observaciones</div> }
              </div>
              @if (m.Imagenes != null && m.Imagenes.Any())
              {
                <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;align-items:center">
                  @foreach (var img in m.Imagenes.Take(4))
                  {
                    <a href="@img.RutaImagen" target="_blank" title="@(img.Descripcion ?? "Ver foto")"
                       style="display:inline-block;border-radius:6px;overflow:hidden;border:1px solid #dde2ec">
                      <img src="@img.RutaImagen"
                           style="width:48px;height:36px;object-fit:cover;display:block"
                           loading="lazy"
                           onerror="this.closest('a').style.display='none'"/>
                    </a>
                  }
                  @if (m.Imagenes.Count > 4)
                  {
                    <span class="text-muted" style="font-size:12px">+@(m.Imagenes.Count - 4) más</span>
                  }
                  <a asp-controller="Movimientos" asp-action="PdfHallazgos" asp-route-id="@m.Id" target="_blank"
                     class="btn btn-secondary btn-sm" style="margin-left:4px">
                    <i class="bi bi-file-earmark-pdf"></i> Hallazgos
                  </a>
                </div>
              }
              @if ((m.TipoMovimiento == "Asignacion" || m.TipoMovimiento == "Prestamo") && (m.Empleado != null || m.MiembroExterno != null || m.Grupo != null))
              {
                <a asp-controller="Movimientos" asp-action="Carta" asp-route-id="@m.Id" class="btn btn-secondary btn-sm" style="margin-top:8px">
                  <i class="bi bi-file-earmark-pdf"></i> Ver carta
                </a>
              }
            </div>
          </li>
        }
      </ul>
    }
  </div>
  <partial name="_Paginacion" model="ViewBag.Paginacion as InventarioTI.ViewModels.PaginacionViewModel"/>
</div>
