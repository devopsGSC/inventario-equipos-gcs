<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] — InventarioTI</title>
  <link rel="icon" type="image/x-icon" href="/gcs_logo.ico"/>
  <link rel="shortcut icon" type="image/x-icon" href="/gcs_logo.ico"/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <style>
    :root {
      --sidebar-w: 230px;
      --navy: #0f1724;
      --navy2: #162032;
      --navy3: #1e2d45;
      --accent: #3b82f6;
      --accent2: #60a5fa;
      --text: #e8edf5;
      --text2: #8fa3be;
      --text3: #5a7494;
      --border: rgba(255,255,255,0.07);
      --bg: #f4f6fa;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --dark-text: #1a2540;
      --dark-text2: #4a5f7a;
      --green: #10b981; --green-bg: #ecfdf5; --green-text: #065f46;
      --amber: #f59e0b; --amber-bg: #fffbeb; --amber-text: #92400e;
      --blue: #3b82f6;  --blue-bg: #eff6ff;  --blue-text: #1e40af;
      --purple: #8b5cf6;--purple-bg:#f5f3ff; --purple-text:#5b21b6;
      --red: #ef4444;   --red-bg: #fef2f2;   --red-text: #991b1b;
      --gray: #6b7280;  --gray-bg: #f9fafb;  --gray-text: #374151;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--dark-text); display: flex; min-height: 100vh; }

    /* SIDEBAR */
    .sidebar {
      width: var(--sidebar-w); background: var(--navy); color: var(--text);
      display: flex; flex-direction: column; position: fixed; height: 100vh;
      top: 0; left: 0; z-index: 100;
    }
    .sidebar-brand {
      padding: 24px 20px 20px;
      border-bottom: 1px solid var(--border);
    }
    .sidebar-brand .logo {
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar-brand .logo-icon {
      width: 34px; height: 34px; background: var(--accent);
      border-radius: 9px; display: flex; align-items: center; justify-content: center;
      font-size: 16px; color: #fff; flex-shrink: 0;
    }
    .sidebar-brand .logo-text { font-size: 15px; font-weight: 600; color: var(--text); line-height: 1.2; }
    .sidebar-brand .logo-sub { font-size: 10px; color: var(--text3); font-weight: 400; }
    .sidebar-nav { flex: 1; padding: 16px 12px; overflow-y: auto; }
    .nav-section { margin-bottom: 24px; }
    .nav-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--text3); padding: 0 8px; margin-bottom: 6px; cursor: pointer; user-select: none; display: flex; align-items: center; justify-content: space-between; }
    .nav-label::after { content: "▾"; font-size: 9px; transition: transform .15s; }
    .nav-section.collapsed .nav-label::after { transform: rotate(-90deg); }
    .nav-section.collapsed .nav-link { display: none; }
    .nav-link {
      display: flex; align-items: center;
      padding: 8px 12px; border-radius: 8px; font-size: 13.5px; font-weight: 500;
      color: var(--text2); text-decoration: none; transition: all .15s; margin-bottom: 1px;
      letter-spacing: 0.01em;
    }
    .nav-link:hover { background: var(--navy3); color: var(--text); }
    .nav-link.active { background: var(--accent); color: #fff; font-weight: 600; }
    /* Sub-enlaces: más pequeños, menos peso, más indentados */
    .nav-link.nav-sub {
      position: relative;
      padding: 6px 12px 6px 20px;
      font-size: 12.5px;
      font-weight: 400;
      color: var(--text3);
      margin-bottom: 0;
    }
    .nav-link.nav-sub:hover { background: transparent; color: var(--text2); }
    .nav-link.nav-sub.active { background: var(--accent); color: #fff; font-weight: 500; }
    /* Árbol de conexión: línea vertical (tronco) + línea horizontal (rama, más tenue) */
    .nav-link.nav-sub::before,
    .nav-link.nav-sub::after {
      content: '';
      position: absolute;
      left: 10px;
    }
    .nav-link.nav-sub::before {
      top: 0; bottom: 0; width: 1px;
      background: rgba(255,255,255,.16);
    }
    .nav-link.nav-sub::after {
      top: 50%; width: 8px; height: 1px;
      background: rgba(255,255,255,.09);
    }
    /* Último subitem de un grupo: el tronco no continúa después de su rama */
    .nav-link.nav-sub:not(:has(+ .nav-link.nav-sub))::before {
      bottom: auto; height: 50%;
    }
    /* Subitem sin padre visible en su sección: sin línea de árbol */
    .nav-link.nav-sub:first-child::before,
    .nav-link.nav-sub:first-child::after {
      display: none;
    }
    .sidebar-footer { padding: 16px; border-top: 1px solid var(--border); font-size: 11px; color: var(--text3); }

    /* MAIN */
    .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid #e5eaf2;
      padding: 0 28px; height: 58px; display: flex; align-items: center;
      justify-content: space-between; position: sticky; top: 0; z-index: 50;
    }
    .topbar-title { font-size: 16px; font-weight: 600; color: var(--dark-text); }
    .topbar-breadcrumb { font-size: 12px; color: var(--dark-text2); }
    .content { padding: 28px; flex: 1; }

    /* CARDS */
    .card { background: var(--surface); border-radius: 12px; border: 1px solid #e5eaf2; }
    .card-header { padding: 16px 20px; border-bottom: 1px solid #f0f3f8; display: flex; align-items: center; justify-content: space-between; }
    .card-title { font-size: 14px; font-weight: 600; color: var(--dark-text); }
    .card-body { padding: 20px; }

    /* STAT CARDS */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; margin-bottom: 24px; }
    .stat-card { background: var(--surface); border-radius: 12px; border: 1px solid #e5eaf2; padding: 18px 20px; }
    .stat-label { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: .05em; color: var(--dark-text2); margin-bottom: 8px; }
    .stat-value { font-size: 28px; font-weight: 600; line-height: 1; color: var(--dark-text); }
    .stat-sub { font-size: 11px; color: var(--dark-text2); margin-top: 4px; }
    .stat-card.accent { background: var(--navy); border-color: var(--navy); }
    .stat-card.accent .stat-label { color: var(--text3); }
    .stat-card.accent .stat-value { color: var(--text); }

    /* BADGES */
    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 500; }
    .badge-bodega   { background: var(--gray-bg);   color: var(--gray-text); }
    .badge-asignado { background: var(--blue-bg);   color: var(--blue-text); }
    .badge-prestamo { background: var(--purple-bg); color: var(--purple-text); }
    .badge-garantia { background: var(--amber-bg);  color: var(--amber-text); }
    .badge-baja     { background: var(--red-bg);    color: var(--red-text); }
    .badge-green    { background: var(--green-bg);  color: var(--green-text); }

    /* TABLES */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    thead tr { border-bottom: 1px solid #eef0f6; }
    th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--dark-text2); }
    td { padding: 12px 14px; border-bottom: 1px solid #f3f5fb; color: var(--dark-text); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8fafd; }
    .mono { font-family: 'DM Mono', monospace; font-size: 12.5px; }

    /* BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; border: none; cursor: pointer; text-decoration: none; transition: all .15s; line-height: 1; }
    .btn-sm { padding: 5px 11px; font-size: 12px; border-radius: 6px; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #2563eb; color: #fff; }
    .btn-secondary { background: #f1f4f9; color: var(--dark-text); border: 1px solid #e5eaf2; }
    .btn-secondary:hover { background: #e8edf5; color: var(--dark-text); }
    .btn-danger { background: var(--red-bg); color: var(--red-text); border: 1px solid #fecaca; }
    .btn-danger:hover { background: #fee2e2; }
    .btn-success { background: var(--green-bg); color: var(--green-text); border: 1px solid #a7f3d0; }

    /* FORMS */
    .form-group { margin-bottom: 18px; }
    .form-label { display: block; font-size: 12.5px; font-weight: 500; color: var(--dark-text2); margin-bottom: 6px; }
    .form-control {
      width: 100%; padding: 9px 13px; border: 1px solid #dde2ec; border-radius: 8px;
      font-size: 13.5px; font-family: 'DM Sans', sans-serif; color: var(--dark-text);
      background: var(--surface); transition: border-color .15s;
    }
    .form-control:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
    select.form-control { cursor: pointer; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 20px; }
    .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0 20px; }
    .span-2 { grid-column: span 2; }
    .field-error { font-size: 11.5px; color: var(--red-text); margin-top: 4px; }
    .input-note { font-size: 11px; color: var(--dark-text2); margin-top: 4px; }

    /* ALERTS */
    .alert { padding: 11px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
    .alert-success { background: var(--green-bg); color: var(--green-text); border: 1px solid #a7f3d0; }
    .alert-danger  { background: var(--red-bg);   color: var(--red-text);   border: 1px solid #fecaca; }
    .alert-warning { background: var(--amber-bg);  color: var(--amber-text); border: 1px solid #fde68a; }

    /* HISTORY TIMELINE */
    .timeline { list-style: none; padding: 0; position: relative; }
    .timeline::before { content:''; position:absolute; left:20px; top:0; bottom:0; width:2px; background:#eef0f6; }
    .timeline-item { display:flex; gap:16px; margin-bottom:20px; position:relative; }
    .timeline-dot { width:40px; height:40px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:16px; z-index:1; }
    .timeline-body { flex:1; padding-top:8px; }
    .timeline-title { font-size:13.5px; font-weight:600; }
    .timeline-meta { font-size:12px; color:var(--dark-text2); margin-top:3px; }

    /* MISC */
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:22px; }
    .page-title { font-size:20px; font-weight:600; }
    .empty-state { text-align:center; padding:50px 20px; color:var(--dark-text2); }
    .empty-state i { font-size:40px; opacity:.3; display:block; margin-bottom:12px; }
    .divider { height:1px; background:#eef0f6; margin:20px 0; }
    .text-muted { color:var(--dark-text2); font-size:12.5px; }
    .gap-2 { display:flex; gap:8px; flex-wrap:wrap; }

    /* SEARCH BOX */
    .search-box { position:relative; }
    .search-box input { padding-left:38px; }
    .search-box i { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--dark-text2); font-size:15px; }

    /* BIG SEARCH (dashboard) */
    .big-search { display:flex; gap:0; }
    .big-search input { border-radius:10px 0 0 10px; border-right:0; flex:1; padding:11px 16px; font-size:14px; }
    .big-search button { border-radius:0 10px 10px 0; padding:0 20px; font-size:14px; }

    /* RESULT CARD */
    .result-card { background:var(--navy); color:var(--text); border-radius:12px; padding:24px; margin-top:20px; }
    .result-card .rc-name { font-size:18px; font-weight:600; margin-bottom:4px; }
    .result-card .rc-serie { font-family:'DM Mono',monospace; font-size:13px; color:var(--text2); margin-bottom:16px; }
    .result-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .result-field label { font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--text3); }
    .result-field p { font-size:13.5px; color:var(--text); margin-top:2px; }

    /* Tablets y teléfonos: menú como drawer + contenido en una columna */
    @@media(max-width:1024px){
      .sidebar {
        transform: translateX(-100%);
        transition: transform .25s ease;
        z-index: 200;
        box-shadow: 4px 0 24px rgba(0,0,0,.25);
      }
      .sidebar.open { transform: translateX(0); }

      /* Overlay oscuro detrás del drawer */
      .sidebar-overlay {
        display: none;
        position: fixed; inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 199;
      }
      .sidebar-overlay.open { display: block; }

      /* Main ocupa todo el ancho */
      .main { margin-left: 0; }

      /* Topbar: mostrar botón hamburguesa */
      .topbar { padding: 0 16px; }
      .hamburger { display: flex; }

      /* Objetivos de toque más grandes en el drawer táctil */
      .sidebar-nav { padding: 20px 14px; }
      .nav-link { padding: 12px 14px; font-size: 15px; }
      .nav-link.nav-sub { padding: 10px 14px 10px 24px; font-size: 13.5px; }
      .nav-link.nav-sub::before,
      .nav-link.nav-sub::after { left: 12px; }

      /* Contenido con menos padding */
      .content { padding: 16px; }

      /* Grids colapsados */
      .form-grid, .form-grid-3 { grid-template-columns: 1fr; }
      .span-2 { grid-column: span 1; }
      .stats-grid { grid-template-columns: repeat(2,1fr); gap:10px; }

      /* Cualquier grilla de dos columnas fijas → una sola columna */
      [style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
      [style*="grid-template-columns:1fr 320px"] { grid-template-columns: 1fr !important; }
      [style*="grid-template-columns:1fr 300px"] { grid-template-columns: 1fr !important; }

      /* Tablas más compactas */
      td, th { padding: 10px 10px; }

      /* Page header en columna si hay botón */
      .page-header { flex-wrap: wrap; gap: 10px; }
      .page-title { font-size: 17px; }

      /* Result grid a 1 col */
      .result-grid { grid-template-columns: 1fr; }

      /* Tipo grid a 2 cols */
      .tipo-grid { grid-template-columns: repeat(2,1fr) !important; }
    }

    @@media(max-width:480px){
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .topbar-title { font-size: 14px; }
    }
  </style>
</head>
<body>

<!-- Overlay para cerrar sidebar en móvil -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div style="padding:18px 20px 14px">
      <img src="/images/gcs_logo.png" alt="GCS"
           style="width:90px;display:block;filter:brightness(0) invert(1);opacity:.95"/>
      <div style="margin-top:8px">
      </div>
    </div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-label">Principal</div>
      <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")" asp-controller="Home" asp-action="Index" onclick="closeSidebar()">
        Panel general 
      </a>
    </div>
    <div class="nav-section">
      <div class="nav-label">Inventario</div>
      <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Equipos"?"active":"")" asp-controller="Equipos" asp-action="Index" onclick="closeSidebar()">
        Equipos
      </a>
      <a class="nav-link nav-sub" asp-controller="Equipos" asp-action="Index" asp-route-estado="Bodega" onclick="closeSidebar()">
        En bodega
      </a>
      <a class="nav-link nav-sub" asp-controller="Equipos" asp-action="Index" asp-route-estado="Asignado" onclick="closeSidebar()">
        Asignados
      </a>
      <a class="nav-link nav-sub" asp-controller="Equipos" asp-action="Index" asp-route-estado="Prestamo" onclick="closeSidebar()">
        En préstamo
      </a>
      <a class="nav-link nav-sub" asp-controller="Equipos" asp-action="Index" asp-route-estado="EnGarantia" onclick="closeSidebar()">
        En garantía
      </a>
      <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Perifericos"?"active":"")" asp-controller="Perifericos" asp-action="Index" onclick="closeSidebar()">
        Periféricos
      </a>
    </div>
    <div class="nav-section">
      <div class="nav-label">Personas</div>
      <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Empleados"?"active":"")" asp-controller="Empleados" asp-action="Index" onclick="closeSidebar()">
        Empleados
      </a>
      @if (await PermisoSvc.TienePermiso(User, "miembrosexternos.ver"))
      {
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="MiembrosExternos"?"active":"")" asp-controller="MiembrosExternos" asp-action="Index" onclick="closeSidebar()">
          Miembros Externos
        </a>
      }
      @if (await PermisoSvc.TienePermiso(User, "grupos.ver"))
      {
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Grupos"?"active":"")" asp-controller="Grupos" asp-action="Index" onclick="closeSidebar()">
          Grupos
        </a>
      }
    </div>
    @if (await PermisoSvc.TienePermiso(User, "licencias.ver"))
    {
      <div class="nav-section">
        <div class="nav-label">Licencias</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Licencias"?"active":"")" asp-controller="Licencias" asp-action="Index" onclick="closeSidebar()">
          Licencias
        </a>
      </div>
    }
    <div class="nav-section">
      <div class="nav-label">Reportes</div>
      @{
        string? _rptCtl    = ViewContext.RouteData.Values["controller"]?.ToString();
        string? _rptAction = ViewContext.RouteData.Values["action"]?.ToString();
        bool    _enRep     = _rptCtl == "Reportes";
      }
      <a class="nav-link @(_enRep && _rptAction == "Index" ? "active" : "")"
         asp-controller="Reportes" asp-action="Index" onclick="closeSidebar()">
        Reportes
      </a>
      <a class="nav-link nav-sub @(_enRep && _rptAction == "Equipos" ? "active" : "")"
         asp-controller="Reportes" asp-action="Equipos" onclick="closeSidebar()">
        Inventario de equipos
      </a>
      <a class="nav-link nav-sub @(_enRep && _rptAction == "Perifericos" ? "active" : "")"
         asp-controller="Reportes" asp-action="Perifericos" onclick="closeSidebar()">
        Inventario de periféricos
      </a>
      <a class="nav-link nav-sub @(_enRep && _rptAction == "Empleados" ? "active" : "")"
         asp-controller="Reportes" asp-action="Empleados" onclick="closeSidebar()">
        Asignaciones por empleado
      </a>
    </div>
    @{
      bool _puedeEquipoCrear  = await PermisoSvc.TienePermiso(User, "equipos.crear");
      bool _puedeCargaMasiva  = await PermisoSvc.TienePermiso(User, "cargamasiva.usar");
      bool _puedePerifCrear   = await PermisoSvc.TienePermiso(User, "perifericos.crear");
      bool _puedeEmpleadoCrear= await PermisoSvc.TienePermiso(User, "empleados.crear");
      bool _puedeMiembroExternoCrear = await PermisoSvc.TienePermiso(User, "miembrosexternos.crear");
      bool _puedeGrupoCrear  = await PermisoSvc.TienePermiso(User, "grupos.crear");
      bool _puedeLicenciaCrear = await PermisoSvc.TienePermiso(User, "licencias.crear");
    }
    @if (_puedeEquipoCrear || _puedeCargaMasiva || _puedePerifCrear || _puedeEmpleadoCrear || _puedeMiembroExternoCrear || _puedeGrupoCrear || _puedeLicenciaCrear)
    {
      <div class="nav-section">
        <div class="nav-label">Acciones</div>
        @if (_puedeEquipoCrear)
        {
          <a class="nav-link" asp-controller="Equipos" asp-action="Create" onclick="closeSidebar()">
            Registrar equipo
          </a>
        }
        @if (_puedeCargaMasiva)
        {
          <a class="nav-link" asp-controller="CargaMasiva" asp-action="Index" onclick="closeSidebar()">
            Carga masiva
          </a>
        }
        @if (_puedePerifCrear)
        {
          <a class="nav-link" asp-controller="Perifericos" asp-action="Create" onclick="closeSidebar()">
            Registrar periférico
          </a>
        }
        @if (_puedeEmpleadoCrear)
        {
          <a class="nav-link" asp-controller="Empleados" asp-action="Create" onclick="closeSidebar()">
            Registrar empleado
          </a>
        }
        @if (_puedeMiembroExternoCrear)
        {
          <a class="nav-link" asp-controller="MiembrosExternos" asp-action="Create" onclick="closeSidebar()">
            Registrar miembro externo
          </a>
        }
        @if (_puedeGrupoCrear)
        {
          <a class="nav-link" asp-controller="Grupos" asp-action="Create" onclick="closeSidebar()">
            Registrar grupo
          </a>
        }
        @if (_puedeLicenciaCrear)
        {
          <a class="nav-link" asp-controller="Licencias" asp-action="Create" onclick="closeSidebar()">
            Registrar tipo de licencia
          </a>
        }
      </div>
    }
    @if (User.IsInRole("Administrador"))
    {
      <div class="nav-section">
        <div class="nav-label">Administración</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Usuarios"?"active":"")"
           asp-controller="Usuarios" asp-action="Index" onclick="closeSidebar()">
          Usuarios del sistema
        </a>
        <a class="nav-link nav-sub @(ViewContext.RouteData.Values["controller"]?.ToString()=="Permisos"?"active":"")"
           asp-controller="Permisos" asp-action="Index" onclick="closeSidebar()">
          Permisos por rol
        </a>
        <a class="nav-link nav-sub @(ViewContext.RouteData.Values["controller"]?.ToString()=="ActualizacionMasiva"?"active":"")"
           asp-controller="ActualizacionMasiva" asp-action="Index" onclick="closeSidebar()">
          Actualización masiva
        </a>
      </div>
    }
    @if (User.IsInRole("Administrador") || User.IsInRole("TecnicoIT"))
    {
      <div class="nav-section">
        <a class="nav-link nav-sub @(ViewContext.RouteData.Values["controller"]?.ToString()=="HistorialMasivo"?"active":"")"
           asp-controller="HistorialMasivo" asp-action="Index" onclick="closeSidebar()">
          Historial de cargas
        </a>
      </div>
    }
  </nav>
  <div class="sidebar-footer">DevOps - GCS &mdash; @DateTime.Now.Year</div>
</aside>

<div class="main">
  <div class="topbar">
    <!-- Botón hamburguesa (solo visible en móvil) -->
    <div style="display:flex;align-items:center;gap:12px">
      <button class="hamburger" id="hamburger" onclick="openSidebar()"
        style="display:none;background:none;border:none;cursor:pointer;padding:6px;border-radius:8px;color:var(--dark-text);font-size:20px">
        <i class="bi bi-list"></i>
      </button>
      <div class="topbar-title">@ViewData["Title"]</div>
    </div>
    <div style="display:flex;align-items:center;gap:12px">
      <div class="text-muted">@DateTime.Now.ToString("dd/MM/yyyy")</div>
      @if (User.Identity?.IsAuthenticated == true)
      {
        <a asp-controller="Auth" asp-action="Perfil" style="text-decoration:none;color:inherit">
          <div style="text-align:right">
            <div style="font-size:13px;font-weight:500">@User.Identity?.Name</div>
            <div class="text-muted" style="font-size:11px">
              @(User.IsInRole("Administrador") ? "Administrador" :
                User.IsInRole("TecnicoIT")     ? "Técnico IT" : "Consulta")
            </div>
          </div>
        </a>
        <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0">
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-secondary btn-sm" title="Cerrar sesión">
            <i class="bi bi-box-arrow-right"></i>
          </button>
        </form>
      }
    </div>
  </div>
  <div class="content">
    @if (TempData["OK"] != null)
    {
      <div class="alert alert-success"><i class="bi bi-check-circle-fill"></i> @TempData["OK"]</div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-danger"><i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]</div>
    }
    @RenderBody()
  </div>
</div>

<div id="customModalOverlay" class="custom-modal-overlay">
  <div class="custom-modal">
    <div class="custom-modal-icon" id="customModalIcon"></div>
    <div class="custom-modal-message" id="customModalMessage"></div>
    <div class="custom-modal-actions">
      <button type="button" class="btn btn-secondary btn-sm" id="customModalCancel">Cancelar</button>
      <button type="button" class="btn btn-primary btn-sm" id="customModalOk">Aceptar</button>
    </div>
  </div>
</div>
<style>
  .custom-modal-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,36,.45); z-index:2000; align-items:center; justify-content:center; padding:16px; }
  .custom-modal-overlay.show { display:flex; }
  .custom-modal { background:var(--surface); border-radius:12px; padding:22px 24px; max-width:380px; width:100%; box-shadow:0 20px 50px rgba(0,0,0,.25); animation:customModalIn .15s ease; }
  @@keyframes customModalIn { from{opacity:0;transform:translateY(-8px) scale(.98)} to{opacity:1;transform:none} }
  .custom-modal-icon { font-size:26px; margin-bottom:10px; }
  .custom-modal-icon.danger { color:var(--red); }
  .custom-modal-icon.warn { color:var(--amber); }
  .custom-modal-icon.info { color:var(--accent); }
  .custom-modal-message { font-size:14px; color:var(--dark-text); line-height:1.5; margin-bottom:18px; white-space:pre-line; }
  .custom-modal-actions { display:flex; justify-content:flex-end; gap:8px; }

  .spinner-inline {
    display:inline-block; width:13px; height:13px; border-radius:50%;
    border:2px solid currentColor; border-bottom-color:transparent; opacity:.85;
    animation:spinnerSpin .6s linear infinite; vertical-align:-2px;
  }
  @@keyframes spinnerSpin { to { transform:rotate(360deg); } }

  .page-loading-overlay { display:none; position:fixed; inset:0; background:rgba(244,246,250,.6); z-index:1500; align-items:center; justify-content:center; flex-direction:column; gap:10px; }
  .page-loading-overlay.show { display:flex; }
  .page-loading-overlay .spinner-inline { width:28px; height:28px; border-width:3px; color:var(--accent); }
  .page-loading-overlay span { font-size:13px; color:var(--dark-text2); font-weight:500; }
</style>
<div id="pageLoadingOverlay" class="page-loading-overlay">
  <span class="spinner-inline"></span>
  <span id="pageLoadingText">Procesando...</span>
</div>
<script>
  function setBtnLoading(btn, loading, textoCarga) {
    if (!btn) return;
    if (loading) {
      if (btn.dataset.originalHtml === undefined) btn.dataset.originalHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = `<span class="spinner-inline"></span> ${textoCarga || 'Procesando...'}`;
    } else {
      btn.disabled = false;
      if (btn.dataset.originalHtml !== undefined) {
        btn.innerHTML = btn.dataset.originalHtml;
        delete btn.dataset.originalHtml;
      }
    }
  }
  function setPageLoading(loading, texto) {
    const overlay = document.getElementById('pageLoadingOverlay');
    document.getElementById('pageLoadingText').textContent = texto || 'Procesando...';
    overlay.classList.toggle('show', !!loading);
  }
  function showCustomModal(message, type, isConfirm) {
    return new Promise(resolve => {
      const overlay = document.getElementById('customModalOverlay');
      const icon    = document.getElementById('customModalIcon');
      const msg     = document.getElementById('customModalMessage');
      const cancel  = document.getElementById('customModalCancel');
      const ok      = document.getElementById('customModalOk');

      icon.className = 'custom-modal-icon ' + type;
      icon.innerHTML = type === 'danger' ? '<i class="bi bi-exclamation-triangle-fill"></i>'
                      : type === 'warn'  ? '<i class="bi bi-question-circle-fill"></i>'
                      : '<i class="bi bi-info-circle-fill"></i>';
      msg.textContent = message;
      cancel.style.display = isConfirm ? 'inline-flex' : 'none';
      ok.textContent = isConfirm ? 'Confirmar' : 'Aceptar';

      function cleanup(result) {
        overlay.classList.remove('show');
        ok.removeEventListener('click', onOk);
        cancel.removeEventListener('click', onCancel);
        document.removeEventListener('keydown', onKey);
        resolve(result);
      }
      function onOk() { cleanup(true); }
      function onCancel() { cleanup(false); }
      function onKey(e) {
        if (e.key === 'Escape') cleanup(false);
        else if (e.key === 'Enter') cleanup(true);
      }

      ok.addEventListener('click', onOk);
      cancel.addEventListener('click', onCancel);
      document.addEventListener('keydown', onKey);
      overlay.classList.add('show');
      ok.focus();
    });
  }
  function customAlert(message, type = 'info') { return showCustomModal(message, type, false); }
  function customConfirm(message, type = 'warn') { return showCustomModal(message, type, true); }

  // Para <form onsubmit="return confirmarSubmit(event, 'mensaje')">: reemplaza al confirm() nativo
  // por el modal personalizado, ya que customConfirm() es asíncrono y onsubmit necesita ser síncrono.
  function confirmarSubmit(e, message, type = 'warn') {
    e.preventDefault();
    const form = e.target;
    customConfirm(message, type).then(ok => {
      if (!ok) return;
      setBtnLoading(form.querySelector('button[type="submit"]'), true, 'Procesando...');
      form.submit();
    });
    return false;
  }
</script>
<script>
  // Responsive sidebar
  const sidebar  = document.getElementById('sidebar');
  const overlay  = document.getElementById('sidebarOverlay');
  const hamburger = document.getElementById('hamburger');

  function openSidebar() {
    sidebar.classList.add('open');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Mostrar/ocultar hamburguesa según ancho
  function checkWidth() {
    hamburger.style.display = window.innerWidth <= 1024 ? 'flex' : 'none';
    if (window.innerWidth > 1024) closeSidebar();
  }
  checkWidth();
  window.addEventListener('resize', checkWidth);

  // Cerrar con tecla Escape
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });

  // Sidebar: secciones plegables (se recuerda el estado por sección)
  document.querySelectorAll('.nav-section').forEach(section => {
    const label = section.querySelector(':scope > .nav-label');
    if (!label) return;
    const key = 'navCollapsed_' + label.textContent.trim();
    if (localStorage.getItem(key) === '1') section.classList.add('collapsed');
    label.addEventListener('click', () => {
      section.classList.toggle('collapsed');
      localStorage.setItem(key, section.classList.contains('collapsed') ? '1' : '0');
    });
  });

  @await RenderSectionAsync("Scripts", required: false)
</script>
</body>
</html>
