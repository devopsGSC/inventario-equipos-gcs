@model InventarioTI.Models.UsuarioApp
@{ ViewData["Title"] = "Editar usuario"; }

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Usuarios</a>
    <div class="page-title" style="margin-top:4px">Editar: @Model.NombreCompleto</div>
  </div>
</div>

<div class="card" style="max-width:640px">
  <div class="card-body">
    <form method="post" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div class="form-group">
        <label class="form-label">Correo electrónico</label>
        <input type="text" class="form-control" value="@Model.Email" disabled/>
      </div>
      <div class="form-grid">
        <div class="form-group span-2">
          <label class="form-label">Nombre completo</label>
          <input type="text" name="nombreCompleto" class="form-control" value="@Model.NombreCompleto" required/>
        </div>
        <div class="form-group">
          <label class="form-label">Cargo</label>
          <input type="text" name="cargo" class="form-control" value="@Model.Cargo"/>
        </div>
        <div class="form-group">
          <label class="form-label">Rol</label>
          <select name="rol" class="form-control" required>
            @foreach (var r in ViewBag.Roles as string[] ?? [])
            { <option value="@r" selected="@(ViewBag.RolActual == r ? "selected" : null)">@r</option> }
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Nueva contraseña</label>
          <input type="password" name="passwordNueva" class="form-control"/>
          <div class="input-note">Déjalo en blanco para no cambiarla.</div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Firma del responsable IT</label>
        @if (!string.IsNullOrEmpty(Model.RutaFirmaIT))
        {
          <div style="margin-bottom:10px">
            <img src="@Model.RutaFirmaIT" style="max-height:60px;border:1px solid #dde2ec;border-radius:6px;padding:4px"/>
            <div class="text-muted" style="font-size:12px;margin-top:4px">Firma actual — sube otra para reemplazarla</div>
          </div>
        }
        <input type="file" name="firmaIT" class="form-control" accept="image/jpeg,image/png,image/webp"/>
        <div class="input-note">JPG, PNG o WEBP. Fondo blanco o transparente. Máx. 2 MB.</div>
      </div>

      <div class="gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar cambios</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
