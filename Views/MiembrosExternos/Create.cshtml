@model MiembroExterno
@{ ViewData["Title"] = "Registrar miembro externo"; }
<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Miembros Externos</a>
    <div class="page-title" style="margin-top:4px">Registrar miembro externo</div>
  </div>
</div>
<div class="card" style="max-width:640px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div class="form-grid">
        <div class="form-group span-2">
          <label class="form-label" asp-for="Nombre"></label>
          <input asp-for="Nombre" class="form-control" placeholder="Nombre completo"/>
          <span asp-validation-for="Nombre" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="Organizacion">Organización</label>
          <input asp-for="Organizacion" class="form-control" placeholder="Ej: Empresa contratista"/>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="Identificacion">Identificación</label>
          <input asp-for="Identificacion" class="form-control" placeholder="DUI u otro documento"/>
        </div>
        <div class="form-group span-2">
          <label class="form-label" asp-for="Referencia">Referencia / cargo</label>
          <input asp-for="Referencia" class="form-control" placeholder="Ej: Contacto técnico"/>
        </div>
      </div>
      <div class="gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Registrar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
