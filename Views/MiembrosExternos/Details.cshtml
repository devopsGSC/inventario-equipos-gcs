@model MiembroExterno
@using InventarioTI.Models
@{
  ViewData["Title"] = Model.Nombre;
  var equipos            = ViewBag.EquiposActuales as List<Movimiento>       ?? new List<Movimiento>();
  var perifsActuales     = ViewBag.PerifsActuales as List<EquipoPeriferico> ?? new List<EquipoPeriferico>();
  var historialPerifs    = ViewBag.HistorialPerifericos as List<EquipoPeriferico> ?? new List<EquipoPeriferico>();
  var licenciasActuales  = ViewBag.LicenciasActuales as List<LicenciaAsignacion> ?? new List<LicenciaAsignacion>();
  var historialLicencias = ViewBag.HistorialLicencias as List<LicenciaAsignacion> ?? new List<LicenciaAsignacion>();
}

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Miembros Externos</a>
    <div class="page-title" style="margin-top:4px">@Model.Nombre</div>
  </div>
  <div style="display:flex;gap:8px">
    @if (await PermisoSvc.TienePermiso(User, "miembrosexternos.editar"))
    {
      <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary"><i class="bi bi-pencil"></i> Editar</a>
    }
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Datos del miembro externo</div>
      @if (Model.Activo) { <span class="badge badge-green">Activo</span> }
      else { <span class="badge badge-baja">Inactivo</span> }
    </div>
    <div class="card-body">
      <div class="form-grid" style="gap:14px">
        <div>
          <div class="form-label">Organización</div>
          <div style="font-size:14px;font-weight:500">@(Model.Organizacion ?? "—")</div>
        </div>
        <div>
          <div class="form-label">Identificación</div>
          <div style="font-size:14px;font-weight:500">@(Model.Identificacion ?? "—")</div>
        </div>
        <div class="span-2">
          <div class="form-label">Referencia / cargo</div>
          <div style="font-size:14px;font-weight:500">@(Model.Referencia ?? "—")</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Equipos actuales</div>
      <div style="display:flex;gap:8px;align-items:center">
        <span class="badge badge-asignado">@equipos.Count en uso</span>
        @if (Model.Activo && (await PermisoSvc.TienePermiso(User, "movimientos.asignar") || await PermisoSvc.TienePermiso(User, "movimientos.prestamo")))
        {
          <a asp-controller="Equipos" asp-action="Index" asp-route-estado="Bodega" asp-route-paraMiembroExterno="@Model.Id" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Asignar equipo
          </a>
        }
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Equipo</th><th>Tipo</th><th>Movimiento</th></tr></thead>
        <tbody>
          @foreach (var m in equipos)
          {
            <tr>
              <td>
                <a asp-controller="Equipos" asp-action="Details" asp-route-id="@m.EquipoId" style="color:var(--accent);text-decoration:none;font-weight:500">@m.Equipo?.NombreEquipo</a>
                <div class="mono text-muted">@m.Equipo?.NumeroSerie</div>
              </td>
              <td>@m.Equipo?.TipoEquipo?.Nombre</td>
              <td>@m.TipoMovimiento<div class="text-muted">@m.FechaInicio.ToString("dd/MM/yyyy")</div></td>
            </tr>
          }
          @if (!equipos.Any())
          {
            <tr><td colspan="3"><div class="empty-state" style="padding:20px"><i class="bi bi-laptop"></i>Sin equipos asignados.</div></td></tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@if (perifsActuales.Any())
{
<div style="margin-top:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Periféricos asignados</div>
      <span class="badge badge-asignado">@perifsActuales.Count en uso</span>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Marca / Modelo</th>
            <th>Número de serie</th>
            <th>Vía equipo</th>
            <th>Desde</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var ep in perifsActuales)
          {
            <tr>
              <td>@ep.Periferico?.TipoPeriferico?.Nombre</td>
              <td>
                <a asp-controller="Perifericos" asp-action="Details" asp-route-id="@ep.PerifericoId"
                   style="color:var(--accent);text-decoration:none;font-weight:500">
                  @ep.Periferico?.Marca @ep.Periferico?.Modelo
                </a>
              </td>
              <td><span class="mono text-muted">@ep.Periferico?.NumeroSerie</span></td>
              <td class="text-muted">
                @if (ep.EquipoId != null)
                {
                  <a asp-controller="Equipos" asp-action="Details" asp-route-id="@ep.EquipoId"
                     style="color:var(--accent);text-decoration:none;font-size:13px">@ep.Equipo?.NombreEquipo</a>
                }
                else { <span>—</span> }
              </td>
              <td>@ep.FechaAsignacion.ToString("dd/MM/yyyy")</td>
              <td>
                <a asp-controller="Perifericos" asp-action="DescargarCartaDirecta"
                   asp-route-asignacionId="@ep.Id" target="_blank"
                   class="btn btn-secondary btn-sm">
                  <i class="bi bi-file-earmark-pdf"></i>
                </a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>
}

<div style="margin-top:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Historial de periféricos</div>
      <span class="badge badge-asignado">@historialPerifs.Count registro(s)</span>
    </div>
    @if (historialPerifs.Any())
    {
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Periférico</th>
              <th>Tipo</th>
              <th>Vía equipo</th>
              <th>Desde</th>
              <th>Hasta</th>
              <th>Duración</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var ep in historialPerifs)
            {
              var esActivo  = !ep.FechaDesvinculacion.HasValue;
              var esDirecto = ep.EquipoId == null;
              var dias      = ep.FechaDesvinculacion.HasValue
                ? (int)(ep.FechaDesvinculacion.Value - ep.FechaAsignacion).TotalDays
                : (int)(DateTime.Today - ep.FechaAsignacion).TotalDays;
              <tr>
                <td>
                  <a asp-controller="Perifericos" asp-action="Details" asp-route-id="@ep.PerifericoId"
                     style="color:var(--accent);text-decoration:none;font-weight:500">
                    @ep.Periferico?.Marca @ep.Periferico?.Modelo
                  </a>
                  <div class="mono text-muted" style="font-size:11px">@ep.Periferico?.NumeroSerie</div>
                </td>
                <td>
                  @if (esDirecto)
                  {
                    <span class="badge badge-asignado">Directo</span>
                  }
                  else
                  {
                    <span class="badge badge-bodega">Vía equipo</span>
                  }
                </td>
                <td class="text-muted">
                  @if (ep.Equipo != null)
                  {
                    <a asp-controller="Equipos" asp-action="Details" asp-route-id="@ep.EquipoId"
                       style="color:var(--accent);text-decoration:none;font-size:13px">@ep.Equipo.NombreEquipo</a>
                  }
                  else { <span>—</span> }
                </td>
                <td class="text-muted">@ep.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                <td>
                  @if (esActivo)
                  {
                    <span class="badge badge-green">Activo</span>
                  }
                  else
                  {
                    <span class="text-muted">@ep.FechaDesvinculacion!.Value.ToString("dd/MM/yyyy")</span>
                  }
                </td>
                <td class="text-muted" style="font-size:12.5px">
                  @if (dias == 0)      { <span>Hoy</span> }
                  else if (dias == 1)  { <span>1 día</span> }
                  else if (dias < 30)  { <span>@dias días</span> }
                  else if (dias < 365) { <span>@(dias / 30) mes(es)</span> }
                  else                 { <span>@(dias / 365) año(s)</span> }
                  @if (esActivo) { <span class="text-muted"> (en curso)</span> }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
    else
    {
      <div class="card-body">
        <div class="empty-state">
          <i class="bi bi-clock-history"></i> Sin historial de periféricos.
        </div>
      </div>
    }
  </div>
</div>

@if (licenciasActuales.Any())
{
<div style="margin-top:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Licencias asignadas</div>
      <span class="badge badge-asignado">@licenciasActuales.Count en uso</span>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Licencia</th><th>Vía equipo</th><th>Desde</th></tr></thead>
        <tbody>
          @foreach (var la in licenciasActuales)
          {
            <tr>
              <td>
                <a asp-controller="Licencias" asp-action="Details" asp-route-id="@la.TipoLicenciaId"
                   style="color:var(--accent);text-decoration:none;font-weight:500">@la.TipoLicencia?.Nombre</a>
              </td>
              <td class="text-muted">
                @if (la.EquipoId != null)
                {
                  <a asp-controller="Equipos" asp-action="Details" asp-route-id="@la.EquipoId"
                     style="color:var(--accent);text-decoration:none;font-size:13px">@la.Equipo?.NombreEquipo</a>
                }
                else { <span>—</span> }
              </td>
              <td>@la.FechaAsignacion.ToString("dd/MM/yyyy")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>
}

<div style="margin-top:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Historial de licencias</div>
      <span class="badge badge-asignado">@historialLicencias.Count registro(s)</span>
    </div>
    @if (historialLicencias.Any())
    {
      <div class="table-wrap">
        <table>
          <thead><tr><th>Licencia</th><th>Vía equipo</th><th>Desde</th><th>Estado</th></tr></thead>
          <tbody>
            @foreach (var la in historialLicencias)
            {
              var esDirecto = la.EquipoId == null;
              <tr>
                <td>
                  <a asp-controller="Licencias" asp-action="Details" asp-route-id="@la.TipoLicenciaId"
                     style="color:var(--accent);text-decoration:none;font-weight:500">@la.TipoLicencia?.Nombre</a>
                </td>
                <td>
                  @if (esDirecto) { <span class="badge badge-asignado">Directo</span> }
                  else { <span class="badge badge-bodega">Vía equipo</span> }
                </td>
                <td class="text-muted">@la.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                <td>
                  @if (!la.FechaDesvinculacion.HasValue) { <span class="badge badge-green">Activa</span> }
                  else { <span class="text-muted">@la.FechaDesvinculacion.Value.ToString("dd/MM/yyyy")</span> }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
    else
    {
      <div class="card-body">
        <div class="empty-state">
          <i class="bi bi-clock-history"></i> Sin historial de licencias.
        </div>
      </div>
    }
  </div>
</div>
