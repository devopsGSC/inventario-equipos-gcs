@model List<Equipo>
@using InventarioTI.Models
@using InventarioTI.ViewModels
@{
    ViewData["Title"] = "Reporte de Equipos";

    var movs       = ViewBag.MovsActivos as Dictionary<int, Movimiento> ?? new Dictionary<int, Movimiento>();
    var pagInfo    = ViewBag.Paginacion  as PaginacionViewModel;
    var total      = (int)(ViewBag.TotalSinPaginar ?? 0);
    var tiposEq    = ViewBag.TiposEquipo  as List<string> ?? new List<string>();
    var marcas     = ViewBag.Marcas       as List<string> ?? new List<string>();
    var deptos     = ViewBag.Departamentos as List<string> ?? new List<string>();
    var sitios     = ViewBag.Sitios       as List<string> ?? new List<string>();

    string buscar           = ViewBag.Buscar          ?? "";
    string tipoEquipo       = ViewBag.TipoEquipo       ?? "";
    string estadoEquipo     = ViewBag.EstadoEquipo     ?? "";
    string marcaEquipo      = ViewBag.MarcaEquipo      ?? "";
    string departamento     = ViewBag.Departamento     ?? "";
    string empleadoId       = ViewBag.EmpleadoId       ?? "";
    string miembroExternoId = ViewBag.MiembroExternoId ?? "";
    string grupoId          = ViewBag.GrupoId          ?? "";
    string sitioFiltro      = ViewBag.SitioFiltro      ?? "";
    string fechaCompraDesde = ViewBag.FechaCompraDesde ?? "";
    string fechaCompraHasta = ViewBag.FechaCompraHasta ?? "";
    string fechaGarDesde    = ViewBag.FechaGarantiaDesde ?? "";
    string fechaGarHasta    = ViewBag.FechaGarantiaHasta ?? "";
    bool garantiaVencida    = ViewBag.GarantiaVencida  is bool gv && gv;
    bool garantiaPorVencer  = ViewBag.GarantiaPorVencer is bool gp && gp;
    int  garantiaDias       = ViewBag.GarantiaDias != null ? (int)ViewBag.GarantiaDias : 30;
    bool sinAsignar         = ViewBag.SinAsignar  is bool sa && sa;
    int? diasEnBodega       = ViewBag.DiasEnBodega as int?;

    // Build export URL preserving current filters
    var exportParams = Context.Request.Query
        .Where(kv => kv.Key != "formato" && kv.Key != "pagina")
        .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value.ToString())}");
    var exportBase   = "/Reportes/Equipos?" + string.Join("&", exportParams);
}

<style>
.filtro-chip {
    display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;
    border:1.5px solid var(--border);background:var(--surface);
    font-size:12px;font-weight:500;cursor:pointer;transition:.15s;user-select:none;
}
.filtro-chip:hover { border-color:var(--accent); }
.filtro-chip.chip-active { background:var(--accent);border-color:var(--accent);color:#fff; }
.chip-extra { display:none;margin-left:6px; }
.chip-active + .chip-extra, .chip-active .chip-extra { display:inline-flex; }
</style>

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Reportes</a>
    <div class="page-title" style="margin-top:4px">Inventario de equipos</div>
  </div>
  @if (Model.Any())
  {
    <div style="display:flex;gap:8px">
      <a href="@exportBase&formato=excel" class="btn btn-secondary btn-sm"><i class="bi bi-file-earmark-excel"></i> Excel</a>
      <a href="@exportBase&formato=csv"   class="btn btn-secondary btn-sm"><i class="bi bi-filetype-csv"></i> CSV</a>
      <a href="@exportBase&formato=pdf"   class="btn btn-secondary btn-sm"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
    </div>
  }
</div>

<div class="card" style="margin-bottom:16px">
  <form method="get" asp-action="Equipos" style="padding:16px 20px">
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
      <div>
        <label class="form-label">Búsqueda general</label>
        <input name="buscar" value="@buscar" class="form-control" placeholder="Nombre, serie, marca, modelo…" />
      </div>
      <div>
        <label class="form-label">Tipo de equipo</label>
        <select name="tipoEquipo" class="form-control">
          <option value="">Todos los tipos</option>
          @foreach (var t in tiposEq)
          { <option value="@t" selected="@(tipoEquipo == t ? "selected" : null)">@t</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Estado</label>
        <select name="estadoEquipo" class="form-control">
          <option value="">Todos los estados</option>
          @foreach (var e in new[]{"Bodega","Asignado","Prestamo","EnGarantia","Baja"})
          { <option value="@e" selected="@(estadoEquipo == e ? "selected" : null)">@e</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Marca</label>
        <select name="marcaEquipo" class="form-control">
          <option value="">Todas las marcas</option>
          @foreach (var m in marcas)
          { <option value="@m" selected="@(marcaEquipo == m ? "selected" : null)">@m</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Departamento</label>
        <select name="departamento" class="form-control">
          <option value="">Todos los departamentos</option>
          @foreach (var d in deptos)
          { <option value="@d" selected="@(departamento == d ? "selected" : null)">@d</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Empleado</label>
        <select name="empleadoId" class="form-control">
          <option value="">Todos</option>
          @foreach (dynamic emp in ViewBag.Empleados ?? new List<object>())
          {
            bool sel = empleadoId == emp.Id.ToString();
            <option value="@emp.Id" selected="@(sel ? "selected" : null)">@emp.Nombre</option>
          }
        </select>
      </div>
      <div>
        <label class="form-label">Sitio</label>
        <select name="sitio" class="form-control">
          <option value="">Todos los sitios</option>
          @foreach (var s in sitios)
          { <option value="@s" selected="@(sitioFiltro == s ? "selected" : null)">@s</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Miembro externo</label>
        <select name="miembroExternoId" class="form-control">
          <option value="">Todos</option>
          @foreach (dynamic m in ViewBag.MiembrosExternos ?? new List<object>())
          {
            bool sel = miembroExternoId == m.Id.ToString();
            <option value="@m.Id" selected="@(sel ? "selected" : null)">@m.Nombre</option>
          }
        </select>
      </div>
      <div>
        <label class="form-label">Grupo</label>
        <select name="grupoId" class="form-control">
          <option value="">Todos</option>
          @foreach (dynamic g in ViewBag.Grupos ?? new List<object>())
          {
            bool sel = grupoId == g.Id.ToString();
            <option value="@g.Id" selected="@(sel ? "selected" : null)">@g.Nombre</option>
          }
        </select>
      </div>
    </div>

    <div style="margin-top:12px">
      <label class="form-label">Fechas de compra</label>
      <div style="display:flex;gap:10px">
        <input type="date" name="fechaCompraDesde" value="@fechaCompraDesde" class="form-control" style="max-width:160px" />
        <span style="align-self:center;color:var(--text-muted)">—</span>
        <input type="date" name="fechaCompraHasta" value="@fechaCompraHasta" class="form-control" style="max-width:160px" />
      </div>
    </div>
    <div style="margin-top:10px">
      <label class="form-label">Fechas de garantía</label>
      <div style="display:flex;gap:10px">
        <input type="date" name="fechaGarantiaDesde" value="@fechaGarDesde" class="form-control" style="max-width:160px" />
        <span style="align-self:center;color:var(--text-muted)">—</span>
        <input type="date" name="fechaGarantiaHasta" value="@fechaGarHasta" class="form-control" style="max-width:160px" />
      </div>
    </div>

    <div style="margin-top:14px;display:flex;flex-wrap:wrap;gap:8px;align-items:center">
      <span class="form-label" style="margin-bottom:0">Filtros rápidos:</span>

      <label class="filtro-chip @(garantiaVencida ? "chip-active" : "")" id="chip-gv">
        <input type="checkbox" name="garantiaVencida" value="true" @(garantiaVencida ? "checked" : "") style="display:none" onchange="this.closest('.filtro-chip').classList.toggle('chip-active',this.checked)" />
        <i class="bi bi-shield-x"></i> Garantía vencida
      </label>

      <label class="filtro-chip @(garantiaPorVencer ? "chip-active" : "")" id="chip-gpv">
        <input type="checkbox" name="garantiaPorVencer" value="true" @(garantiaPorVencer ? "checked" : "") style="display:none" onchange="toggleChip(this,'extra-gpv')" />
        <i class="bi bi-shield-exclamation"></i> Por vencer
      </label>
      <span id="extra-gpv" style="display:@(garantiaPorVencer?"flex":"none");align-items:center;gap:4px">
        <span style="font-size:12px;color:var(--text-muted)">en</span>
        <input type="number" name="garantiaDias" value="@garantiaDias" min="1" max="365" style="width:60px" class="form-control" />
        <span style="font-size:12px;color:var(--text-muted)">días</span>
      </span>

      <label class="filtro-chip @(sinAsignar ? "chip-active" : "")">
        <input type="checkbox" name="sinAsignar" value="true" @(sinAsignar ? "checked" : "") style="display:none" onchange="toggleChip(this,'extra-sa')" />
        <i class="bi bi-archive"></i> Sin asignar (bodega)
      </label>
      <span id="extra-sa" style="display:@(sinAsignar?"flex":"none");align-items:center;gap:4px">
        <span style="font-size:12px;color:var(--text-muted)">&gt;</span>
        <input type="number" name="diasEnBodega" value="@(diasEnBodega?.ToString()??"")" min="1" style="width:60px" class="form-control" placeholder="días" />
        <span style="font-size:12px;color:var(--text-muted)">días</span>
      </span>
    </div>

    <div style="margin-top:14px;display:flex;gap:8px">
      <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Buscar</button>
      <a asp-action="Equipos" class="btn btn-secondary">Limpiar</a>
    </div>
  </form>
</div>

@if (!string.IsNullOrEmpty(buscar) || !string.IsNullOrEmpty(tipoEquipo) || !string.IsNullOrEmpty(estadoEquipo) ||
     !string.IsNullOrEmpty(marcaEquipo) || !string.IsNullOrEmpty(departamento) || !string.IsNullOrEmpty(empleadoId) ||
     !string.IsNullOrEmpty(miembroExternoId) || !string.IsNullOrEmpty(grupoId) ||
     !string.IsNullOrEmpty(sitioFiltro) ||
     garantiaVencida || garantiaPorVencer || sinAsignar)
{
  <div style="margin-bottom:12px;display:flex;flex-wrap:wrap;gap:8px;align-items:center">
    <span style="font-size:12px;color:var(--text-muted)">Filtros activos:</span>
    @if (!string.IsNullOrEmpty(buscar))
    { <span class="badge badge-bodega"><i class="bi bi-search"></i> @buscar <a asp-action="Equipos" asp-all-route-data='@QuitarFiltro("buscar")' style="color:inherit;margin-left:4px">×</a></span> }
    @if (!string.IsNullOrEmpty(tipoEquipo))
    { <span class="badge badge-bodega">Tipo: @tipoEquipo</span> }
    @if (!string.IsNullOrEmpty(estadoEquipo))
    { <span class="badge badge-bodega">Estado: @estadoEquipo</span> }
    @if (!string.IsNullOrEmpty(marcaEquipo))
    { <span class="badge badge-bodega">Marca: @marcaEquipo</span> }
    @if (!string.IsNullOrEmpty(departamento))
    { <span class="badge badge-bodega">Depto: @departamento</span> }
    @if (!string.IsNullOrEmpty(sitioFiltro))
    { <span class="badge badge-bodega"><i class="bi bi-geo-alt"></i> Sitio: @sitioFiltro</span> }
    @if (garantiaVencida)
    { <span class="badge badge-baja"><i class="bi bi-shield-x"></i> Garantía vencida</span> }
    @if (garantiaPorVencer)
    { <span class="badge badge-prestamo"><i class="bi bi-shield-exclamation"></i> Por vencer</span> }
    @if (sinAsignar)
    { <span class="badge badge-bodega"><i class="bi bi-archive"></i> Sin asignar</span> }
    <span style="font-size:12px;color:var(--text-muted)">— @total resultado(s)</span>
  </div>
}

<div class="card">
  <div class="card-header">
    <div class="card-title">Equipos</div>
    <span class="text-muted" style="font-size:13px">@total equipo(s)</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Equipo</th><th>Tipo</th><th>Serie</th><th>Estado</th>
          <th>RAM</th><th>Procesador</th><th>Almacenamiento</th><th>Plan</th>
          <th>Responsable</th><th>Dpto. / Org.</th><th>Sitio</th><th>Fecha asig.</th>
          <th>Compra</th><th>Garantía</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var e in Model)
        {
          movs.TryGetValue(e.Id, out var m);
          <tr>
            <td>
              <a asp-controller="Equipos" asp-action="Details" asp-route-id="@e.Id"
                 style="color:var(--accent);text-decoration:none;font-weight:500">@e.NombreEquipo</a>
              <div class="text-muted mono" style="font-size:11px">@e.Marca @e.Modelo</div>
            </td>
            <td>@e.TipoEquipo?.Nombre</td>
            <td><span class="mono text-muted">@e.NumeroSerie</span></td>
            <td><partial name="_EstadoBadge" model="@e.Estado" /></td>
            <td class="text-muted" style="font-size:12.5px">@(e.RAM ?? "—")</td>
            <td class="text-muted" style="font-size:12.5px">@(e.Procesador ?? "—")</td>
            <td class="text-muted" style="font-size:12.5px">@(e.Almacenamiento ?? "—")</td>
            <td class="text-muted" style="font-size:12.5px">@(e.PlanData?.Nombre ?? "—")</td>
            <td>
              @if (m != null)
              { <span>@m.NombreResponsable</span> }
              else { <span class="text-muted">—</span> }
            </td>
            <td>@(m?.Empleado?.Departamento?.Nombre ?? m?.MiembroExterno?.Organizacion ?? m?.Grupo?.Descripcion ?? "—")</td>
            <td class="text-muted" style="font-size:12.5px">
              @if (m?.Sitio != null)
              { <span><i class="bi bi-geo-alt"></i> @m.Sitio.Nombre</span> }
              else { <span>—</span> }
            </td>
            <td>@(m != null ? m.FechaInicio.ToString("dd/MM/yy") : "—")</td>
            <td>@(e.FechaCompra?.ToString("dd/MM/yy") ?? "—")</td>
            <td>
              @if (e.FechaGarantia.HasValue)
              {
                var dias = (e.FechaGarantia.Value - DateTime.Today).Days;
                var cls  = dias < 0 ? "text-danger" : dias <= 30 ? "text-warning" : "";
                <span class="@cls">@e.FechaGarantia.Value.ToString("dd/MM/yy")</span>
              }
              else { <span class="text-muted">—</span> }
            </td>
          </tr>
        }
        @if (!Model.Any())
        {
          <tr><td colspan="14">
            <div class="empty-state"><i class="bi bi-laptop"></i>No se encontraron equipos con los filtros aplicados.</div>
          </td></tr>
        }
      </tbody>
    </table>
  </div>
  @if (pagInfo != null && pagInfo.TotalPaginas > 1)
  { <div style="padding:12px 20px"><partial name="_Paginacion" model="pagInfo" /></div> }
</div>

@functions {
    Dictionary<string, string> QuitarFiltro(string key)
    {
        return Context.Request.Query
            .Where(kv => kv.Key != key && kv.Key != "pagina")
            .ToDictionary(kv => kv.Key, kv => kv.Value.ToString());
    }
}

<script>
function toggleChip(cb, extraId) {
    cb.closest('.filtro-chip').classList.toggle('chip-active', cb.checked);
    const extra = document.getElementById(extraId);
    if (extra) extra.style.display = cb.checked ? 'flex' : 'none';
}
</script>
