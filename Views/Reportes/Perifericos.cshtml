@model List<Periferico>
@using InventarioTI.Models
@using InventarioTI.ViewModels
@{
    ViewData["Title"] = "Reporte de Periféricos";

    var asignActivas    = ViewBag.AsignActivas    as Dictionary<int, EquipoPeriferico> ?? new Dictionary<int, EquipoPeriferico>();
    var pagInfo         = ViewBag.Paginacion      as PaginacionViewModel;
    var total           = (int)(ViewBag.TotalSinPaginar ?? 0);
    var tiposPf         = ViewBag.TiposPeriferico as List<string> ?? new List<string>();
    var marcas          = ViewBag.Marcas          as List<string> ?? new List<string>();

    string buscar          = ViewBag.Buscar           ?? "";
    string tipoPeriferico  = ViewBag.TipoPeriferico   ?? "";
    string estadoPeriferico= ViewBag.EstadoPeriferico ?? "";
    string marcaPeriferico = ViewBag.MarcaPeriferico  ?? "";
    string empleadoId      = ViewBag.EmpleadoId       ?? "";
    string miembroExternoId= ViewBag.MiembroExternoId ?? "";
    string grupoId         = ViewBag.GrupoId          ?? "";
    string fechaCompraDesde= ViewBag.FechaCompraDesde ?? "";
    string fechaCompraHasta= ViewBag.FechaCompraHasta ?? "";

    var exportParams = Context.Request.Query
        .Where(kv => kv.Key != "formato" && kv.Key != "pagina")
        .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value.ToString())}");
    var exportBase   = "/Reportes/Perifericos?" + string.Join("&", exportParams);
}

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Reportes</a>
    <div class="page-title" style="margin-top:4px">Inventario de periféricos</div>
  </div>
  @if (Model.Any())
  {
    <div style="display:flex;gap:8px">
      <a href="@exportBase&formato=excel" class="btn btn-secondary btn-sm"><i class="bi bi-file-earmark-excel"></i> Excel</a>
      <a href="@exportBase&formato=csv"   class="btn btn-secondary btn-sm"><i class="bi bi-filetype-csv"></i> CSV</a>
      <a href="@exportBase&formato=pdf"   class="btn btn-secondary btn-sm"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
    </div>
  }
</div>

<div class="card" style="margin-bottom:16px">
  <form method="get" asp-action="Perifericos" style="padding:16px 20px">
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
      <div>
        <label class="form-label">Búsqueda general</label>
        <input name="buscar" value="@buscar" class="form-control" placeholder="Marca, modelo, serie…" />
      </div>
      <div>
        <label class="form-label">Tipo de periférico</label>
        <select name="tipoPeriferico" class="form-control">
          <option value="">Todos los tipos</option>
          @foreach (var t in tiposPf)
          { <option value="@t" selected="@(tipoPeriferico == t ? "selected" : null)">@t</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Estado</label>
        <select name="estadoPeriferico" class="form-control">
          <option value="">Todos los estados</option>
          @foreach (var s in new[]{"Bodega","Asignado","Prestamo","EnGarantia","Baja"})
          { <option value="@s" selected="@(estadoPeriferico == s ? "selected" : null)">@s</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Marca</label>
        <select name="marcaPeriferico" class="form-control">
          <option value="">Todas las marcas</option>
          @foreach (var m in marcas)
          { <option value="@m" selected="@(marcaPeriferico == m ? "selected" : null)">@m</option> }
        </select>
      </div>
      <div>
        <label class="form-label">Empleado</label>
        <select name="empleadoId" class="form-control">
          <option value="">Todos</option>
          @foreach (dynamic emp in ViewBag.Empleados ?? new List<object>())
          {
            bool sel = empleadoId == emp.Id.ToString();
            <option value="@emp.Id" selected="@(sel ? "selected" : null)">@emp.Nombre</option>
          }
        </select>
      </div>
      <div>
        <label class="form-label">Miembro externo</label>
        <select name="miembroExternoId" class="form-control">
          <option value="">Todos</option>
          @foreach (dynamic m in ViewBag.MiembrosExternos ?? new List<object>())
          {
            bool sel = miembroExternoId == m.Id.ToString();
            <option value="@m.Id" selected="@(sel ? "selected" : null)">@m.Nombre</option>
          }
        </select>
      </div>
      <div>
        <label class="form-label">Grupo</label>
        <select name="grupoId" class="form-control">
          <option value="">Todos</option>
          @foreach (dynamic g in ViewBag.Grupos ?? new List<object>())
          {
            bool sel = grupoId == g.Id.ToString();
            <option value="@g.Id" selected="@(sel ? "selected" : null)">@g.Nombre</option>
          }
        </select>
      </div>
    </div>

    <div style="margin-top:12px">
      <label class="form-label">Fecha de compra</label>
      <div style="display:flex;gap:10px">
        <input type="date" name="fechaCompraDesde" value="@fechaCompraDesde" class="form-control" style="max-width:160px" />
        <span style="align-self:center;color:var(--text-muted)">—</span>
        <input type="date" name="fechaCompraHasta" value="@fechaCompraHasta" class="form-control" style="max-width:160px" />
      </div>
    </div>

    <div style="margin-top:14px;display:flex;gap:8px">
      <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Buscar</button>
      <a asp-action="Perifericos" class="btn btn-secondary">Limpiar</a>
    </div>
  </form>
</div>

@if (!string.IsNullOrEmpty(buscar) || !string.IsNullOrEmpty(tipoPeriferico) ||
     !string.IsNullOrEmpty(estadoPeriferico) || !string.IsNullOrEmpty(marcaPeriferico) ||
     !string.IsNullOrEmpty(empleadoId) || !string.IsNullOrEmpty(miembroExternoId) || !string.IsNullOrEmpty(grupoId))
{
  <div style="margin-bottom:12px;display:flex;flex-wrap:wrap;gap:8px;align-items:center">
    <span style="font-size:12px;color:var(--text-muted)">Filtros activos:</span>
    @if (!string.IsNullOrEmpty(buscar))       { <span class="badge badge-bodega"><i class="bi bi-search"></i> @buscar</span> }
    @if (!string.IsNullOrEmpty(tipoPeriferico)){ <span class="badge badge-bodega">Tipo: @tipoPeriferico</span> }
    @if (!string.IsNullOrEmpty(estadoPeriferico)){ <span class="badge badge-bodega">Estado: @estadoPeriferico</span> }
    @if (!string.IsNullOrEmpty(marcaPeriferico)){ <span class="badge badge-bodega">Marca: @marcaPeriferico</span> }
    <span style="font-size:12px;color:var(--text-muted)">— @total resultado(s)</span>
  </div>
}

<div class="card">
  <div class="card-header">
    <div class="card-title">Periféricos</div>
    <span class="text-muted" style="font-size:13px">@total periférico(s)</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Tipo</th><th>Marca / Modelo</th><th>Serie</th><th>Estado</th>
          <th>Equipo adjunto</th><th>Responsable</th><th>Fecha compra</th><th>Registrado</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var p in Model)
        {
          asignActivas.TryGetValue(p.Id, out var ep);
          string equipo, empleado;
          if (ep == null) { equipo = "—"; empleado = "—"; }
          else             { equipo = ep.Equipo?.NombreEquipo ?? "—"; empleado = ep.NombreResponsable; }
          <tr>
            <td>@p.TipoPeriferico?.Nombre</td>
            <td>
              <a asp-controller="Perifericos" asp-action="Details" asp-route-id="@p.Id"
                 style="color:var(--accent);text-decoration:none;font-weight:500">@p.Marca @p.Modelo</a>
            </td>
            <td><span class="mono text-muted">@p.NumeroSerie</span></td>
            <td><partial name="_EstadoBadge" model="@p.Estado" /></td>
            <td>@equipo</td>
            <td>@empleado</td>
            <td>@(p.FechaCompra?.ToString("dd/MM/yy") ?? "—")</td>
            <td>@p.FechaRegistro.ToString("dd/MM/yy")</td>
          </tr>
        }
        @if (!Model.Any())
        {
          <tr><td colspan="8">
            <div class="empty-state"><i class="bi bi-mouse2"></i>No se encontraron periféricos con los filtros aplicados.</div>
          </td></tr>
        }
      </tbody>
    </table>
  </div>
  @if (pagInfo != null && pagInfo.TotalPaginas > 1)
  { <div style="padding:12px 20px"><partial name="_Paginacion" model="pagInfo" /></div> }
</div>
