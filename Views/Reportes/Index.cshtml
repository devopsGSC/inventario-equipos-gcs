@{ ViewData["Title"] = "Reportes"; }

<div class="page-header">
  <div class="page-title">Reportes</div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">

  <a asp-action="Equipos" class="card" style="text-decoration:none;padding:24px;cursor:pointer">
    <i class="bi bi-laptop" style="font-size:28px;color:var(--accent)"></i>
    <div style="font-size:15px;font-weight:600;margin-top:12px">Inventario de equipos</div>
    <div class="text-muted" style="font-size:13px;margin-top:6px">Filtrar por tipo, estado, marca, garantía, empleado y más</div>
  </a>

  <a asp-action="Perifericos" class="card" style="text-decoration:none;padding:24px;cursor:pointer">
    <i class="bi bi-mouse2" style="font-size:28px;color:var(--accent)"></i>
    <div style="font-size:15px;font-weight:600;margin-top:12px">Inventario de periféricos</div>
    <div class="text-muted" style="font-size:13px;margin-top:6px">Filtrar por tipo, estado, marca, empleado y fecha de compra</div>
  </a>

  <a asp-action="Empleados" class="card" style="text-decoration:none;padding:24px;cursor:pointer">
    <i class="bi bi-people" style="font-size:28px;color:var(--accent)"></i>
    <div style="font-size:15px;font-weight:600;margin-top:12px">Asignaciones por empleado</div>
    <div class="text-muted" style="font-size:13px;margin-top:6px">Ver todos los equipos asignados a cada empleado, con historial</div>
  </a>

</div>
