@model EquipoPeriferico
@using InventarioTI.Models
@{
  ViewData["Title"] = Model.TipoMovimiento == "Prestamo" ? "Carta de Préstamo" : "Carta de Compromiso";
  bool esPrestamo = Model.TipoMovimiento == "Prestamo";
}

<div class="page-header">
  <div>
    <a asp-action="Details" asp-route-id="@Model.PerifericoId" class="text-muted" style="text-decoration:none;font-size:13px">
      <i class="bi bi-arrow-left"></i> @Model.Periferico?.Marca @Model.Periferico?.Modelo
    </a>
    <div class="page-title" style="margin-top:4px">
      @(esPrestamo ? "Préstamo de periférico registrado" : "Asignación de periférico registrada")
    </div>
  </div>
  <a asp-action="DescargarCartaDirecta" asp-route-asignacionId="@Model.Id" class="btn btn-primary" target="_blank">
    <i class="bi bi-file-earmark-pdf"></i> Descargar PDF
  </a>
</div>

<div class="card" style="max-width:700px">
  <div class="card-body">
    <div class="alert alert-success">
      <i class="bi bi-check-circle-fill"></i>
      Movimiento registrado. Descargue la carta para que el colaborador la firme.
    </div>

    <div style="background:var(--navy);color:var(--text);border-radius:10px;padding:20px 24px;margin-bottom:20px">
      <div style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);margin-bottom:4px">
        @(esPrestamo ? "Préstamo de periférico" : "Asignación de periférico")
      </div>
      <div style="font-size:18px;font-weight:600">@Model.Periferico?.TipoPeriferico?.Nombre — @Model.Periferico?.Marca @Model.Periferico?.Modelo</div>
      <div style="font-size:13px;color:var(--text2);font-family:'DM Mono',monospace">@Model.Periferico?.NumeroSerie</div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
      <div>
        <div class="form-label">Responsable</div>
        <div style="font-weight:600">@Model.NombreResponsable</div>
        <div class="text-muted">@(Model.Empleado?.CodigoEmpleado ?? Model.MiembroExterno?.Organizacion)</div>
      </div>
      <div>
        <div class="form-label">@(Model.Empleado != null ? "Departamento" : Model.MiembroExterno != null ? "Organización" : "Descripción")</div>
        <div>@(Model.Empleado?.Departamento?.Nombre ?? Model.MiembroExterno?.Organizacion ?? Model.Grupo?.Descripcion ?? "—")</div>
      </div>
      <div>
        <div class="form-label">Fecha</div>
        <div>@Model.FechaAsignacion.ToString("dd/MM/yyyy")</div>
      </div>
      @if (esPrestamo && Model.FechaDevolucionEstimada.HasValue)
      {
        <div>
          <div class="form-label">Devolución estimada</div>
          <div style="color:var(--amber-text);font-weight:500">@Model.FechaDevolucionEstimada.Value.ToString("dd/MM/yyyy")</div>
        </div>
      }
    </div>

    <div class="divider"></div>

    <div class="gap-2">
      <a asp-action="DescargarCartaDirecta" asp-route-asignacionId="@Model.Id" class="btn btn-primary" target="_blank">
        <i class="bi bi-download"></i> Descargar carta PDF
      </a>
      <a asp-action="Details" asp-route-id="@Model.PerifericoId" class="btn btn-secondary">
        Ver detalle del periférico
      </a>
    </div>
  </div>
</div>
