@model Periferico
@using InventarioTI.Models
@{
  ViewData["Title"] = $"{Model.Marca} {Model.Modelo}";
  var movActivo     = ViewBag.MovimientoActivo as Movimiento;
  var asigActiva    = ViewBag.AsignacionActiva as EquipoPeriferico;
  var badgeCls      = Model.Estado switch {
    "Disponible" => "badge-green",
    "Asignado"   => "badge-asignado",
    "Baja"       => "badge-baja",
    _            => "badge-bodega"
  };
}

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px">
      <i class="bi bi-arrow-left"></i> Periféricos
    </a>
    <div class="page-title" style="margin-top:4px">@Model.Marca @Model.Modelo</div>
  </div>
  <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">
    <i class="bi bi-pencil"></i> Editar
  </a>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">

  <!-- Info del periférico -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Información</div>
      <span class="badge @badgeCls">@Model.Estado</span>
    </div>
    <div class="card-body">
      <div class="form-grid" style="gap:14px">
        <div>
          <div class="form-label">Tipo</div>
          <div style="font-size:14px;font-weight:500">@Model.TipoPeriferico?.Nombre</div>
        </div>
        <div>
          <div class="form-label">Marca</div>
          <div style="font-size:14px;font-weight:500">@Model.Marca</div>
        </div>
        <div>
          <div class="form-label">Modelo</div>
          <div style="font-size:14px;font-weight:500">@Model.Modelo</div>
        </div>
        <div>
          <div class="form-label">Número de serie</div>
          <div style="font-size:14px;font-weight:500;font-family:'DM Mono',monospace">@Model.NumeroSerie</div>
        </div>
        <div>
          <div class="form-label">Fecha de compra</div>
          <div style="font-size:14px;font-weight:500">@(Model.FechaCompra?.ToString("dd/MM/yyyy") ?? "—")</div>
        </div>
        <div>
          <div class="form-label">Fecha de registro en sistema</div>
          <div style="font-size:14px;font-weight:500">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Observaciones))
        {
          <div style="grid-column:span 2">
            <div class="form-label">Observaciones</div>
            <div style="font-size:14px">@Model.Observaciones</div>
          </div>
        }
      </div>
      @if (Model.Estado == "Disponible")
      {
        <div style="margin-top:16px;border-top:1px solid #f0f3f8;padding-top:14px">
          <form asp-action="DarDeBaja" asp-route-id="@Model.Id" method="post"
                onsubmit="return confirm('¿Dar de baja este periférico?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-sm">
              <i class="bi bi-x-circle"></i> Dar de baja
            </button>
          </form>
        </div>
      }
      @if (Model.Estado == "Baja")
      {
        <div style="margin-top:16px;border-top:1px solid #f0f3f8;padding-top:14px">
          <div class="alert alert-warning" style="margin-bottom:12px;font-size:12.5px">
            <i class="bi bi-info-circle-fill"></i> Este periférico está dado de baja. Puedes reactivarlo para que vuelva al stock disponible.
          </div>
          <form asp-action="Reactivar" asp-route-id="@Model.Id" method="post"
                onsubmit="return confirm('¿Reactivar este periférico? Volverá al stock disponible.')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
              <i class="bi bi-arrow-counterclockwise"></i> Reactivar periférico
            </button>
          </form>
        </div>
      }
    </div>
  </div>

  <!-- Asignado a / Disponible -->
  <div class="card">
    <div class="card-header"><div class="card-title">Asignado a</div></div>
    <div class="card-body">
      @if (asigActiva != null && asigActiva.Equipo != null)
      {
        <!-- Equipo -->
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #f0f3f8">
          <div style="width:40px;height:40px;border-radius:10px;background:var(--blue-bg);color:var(--blue-text);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">
            <i class="bi bi-laptop"></i>
          </div>
          <div>
            <a asp-controller="Equipos" asp-action="Details" asp-route-id="@asigActiva.EquipoId"
               style="font-weight:600;font-size:15px;color:var(--accent);text-decoration:none">
              @asigActiva.Equipo.NombreEquipo
            </a>
            <div class="text-muted" style="font-family:'DM Mono',monospace;font-size:11px">
              @asigActiva.Equipo.NumeroSerie
            </div>
          </div>
        </div>

        <!-- Empleado -->
        @if (movActivo?.Empleado != null)
        {
          var emp = movActivo.Empleado;
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--purple-bg);color:var(--purple-text);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">
              <i class="bi bi-person-fill"></i>
            </div>
            <div>
              <div style="font-weight:600;font-size:14px">@emp.Nombre</div>
              <div class="text-muted">@emp.CodigoEmpleado — @emp.Cargo</div>
            </div>
          </div>
          <div class="form-grid" style="gap:10px">
            <div>
              <div class="form-label">Departamento</div>
              <div style="font-size:13.5px">@emp.Departamento?.Nombre</div>
            </div>
            <div>
              <div class="form-label">DUI</div>
              <div style="font-size:13.5px">@emp.DUI</div>
            </div>
            <div>
              <div class="form-label">Tipo de movimiento</div>
              <div style="font-size:13.5px">@movActivo.TipoMovimiento</div>
            </div>
            <div>
              <div class="form-label">Desde</div>
              <div style="font-size:13.5px">@asigActiva.FechaAsignacion.ToString("dd/MM/yyyy")</div>
            </div>
          </div>
        }
        else
        {
          <div class="text-muted" style="font-size:13px">
            <i class="bi bi-info-circle"></i> El equipo está en bodega, sin empleado asignado actualmente.
          </div>
        }
      }
      else
      {
        <div class="empty-state" style="padding:30px 0">
          <i class="bi bi-check-circle" style="color:var(--green-text);opacity:1"></i>
          <p style="margin-top:8px;color:var(--green-text);font-weight:500">Disponible en stock</p>
          <p style="font-size:12.5px">Este periférico no está asignado a ningún equipo.</p>
        </div>
      }
    </div>
  </div>
</div>


