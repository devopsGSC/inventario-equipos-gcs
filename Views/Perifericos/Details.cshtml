@model Periferico
@using InventarioTI.Models
@{
  ViewData["Title"] = $"{Model.Marca} {Model.Modelo}";
  var asigActiva    = ViewBag.AsignacionActiva as EquipoPeriferico;
  var badgeCls      = Model.Estado switch {
    "Disponible" => "badge-green",
    "Asignado"   => "badge-asignado",
    "Baja"       => "badge-baja",
    _            => "badge-bodega"
  };
}

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px">
      <i class="bi bi-arrow-left"></i> Periféricos
    </a>
    <div class="page-title" style="margin-top:4px">@Model.Marca @Model.Modelo</div>
  </div>
  @if (await PermisoSvc.TienePermiso(User, "perifericos.editar"))
  {
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">
      <i class="bi bi-pencil"></i> Editar
    </a>
  }
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">

  <!-- Info del periférico -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Información</div>
      <span class="badge @badgeCls">@Model.Estado</span>
    </div>
    <div class="card-body">
      <div class="form-grid" style="gap:14px">
        <div>
          <div class="form-label">Tipo</div>
          <div style="font-size:14px;font-weight:500">@Model.TipoPeriferico?.Nombre</div>
        </div>
        <div>
          <div class="form-label">Marca</div>
          <div style="font-size:14px;font-weight:500">@Model.Marca</div>
        </div>
        <div>
          <div class="form-label">Modelo</div>
          <div style="font-size:14px;font-weight:500">@Model.Modelo</div>
        </div>
        <div>
          <div class="form-label">Número de serie</div>
          <div style="font-size:14px;font-weight:500;font-family:'DM Mono',monospace">@Model.NumeroSerie</div>
        </div>
        <div>
          <div class="form-label">Fecha de compra</div>
          <div style="font-size:14px;font-weight:500">@(Model.FechaCompra?.ToString("dd/MM/yyyy") ?? "—")</div>
        </div>
        <div>
          <div class="form-label">Fecha de registro en sistema</div>
          <div style="font-size:14px;font-weight:500">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Observaciones))
        {
          <div style="grid-column:span 2">
            <div class="form-label">Observaciones</div>
            <div style="font-size:14px">@Model.Observaciones</div>
          </div>
        }
      </div>
      @if (Model.Estado == "Disponible" && (await PermisoSvc.TienePermiso(User, "perifericos.asignar") ||
                                             await PermisoSvc.TienePermiso(User, "perifericos.baja")))
      {
        <div style="margin-top:16px;border-top:1px solid #f0f3f8;padding-top:14px;display:flex;gap:8px;flex-wrap:wrap">
          @if (await PermisoSvc.TienePermiso(User, "perifericos.asignar"))
          {
            <a asp-action="AsignarDirecto" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
              <i class="bi bi-person-check"></i> Asignar / Prestar
            </a>
          }
          @if (await PermisoSvc.TienePermiso(User, "perifericos.baja"))
          {
            <form asp-action="DarDeBaja" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirmarSubmit(event, '¿Dar de baja este periférico?')">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-x-circle"></i> Dar de baja
              </button>
            </form>
          }
        </div>
      }
      @if (Model.Estado == "Asignado" && asigActiva != null && await PermisoSvc.TienePermiso(User, "perifericos.asignar"))
      {
        <div style="margin-top:16px;border-top:1px solid #f0f3f8;padding-top:14px;display:flex;gap:8px;flex-wrap:wrap">
          <a asp-action="Devolver" asp-route-id="@Model.Id" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-return-left"></i> Registrar devolución
          </a>
          @if (asigActiva != null)
          {
            <a asp-action="DescargarCartaDirecta" asp-route-asignacionId="@asigActiva.Id"
               class="btn btn-secondary btn-sm" target="_blank">
              <i class="bi bi-file-earmark-pdf"></i> Descargar carta
            </a>
          }
        </div>
      }
      @if (await PermisoSvc.TienePermiso(User, "perifericos.baja") && Model.Estado == "Baja")
      {
        <div style="margin-top:16px;border-top:1px solid #f0f3f8;padding-top:14px">
          <div class="alert alert-warning" style="margin-bottom:12px;font-size:12.5px">
            <i class="bi bi-info-circle-fill"></i> Este periférico está dado de baja. Puedes reactivarlo para que vuelva al stock disponible.
          </div>
          <form asp-action="Reactivar" asp-route-id="@Model.Id" method="post"
                onsubmit="return confirmarSubmit(event, '¿Reactivar este periférico? Volverá al stock disponible.')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
              <i class="bi bi-arrow-counterclockwise"></i> Reactivar periférico
            </button>
          </form>
        </div>
      }
    </div>
  </div>

  <!-- Asignado a / Disponible -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Asignado a</div>
      @if (asigActiva?.Equipo != null) { <span class="badge badge-bodega">Vía equipo</span> }
    </div>
    <div class="card-body">
      @if (asigActiva != null && (asigActiva.Empleado != null || asigActiva.MiembroExterno != null || asigActiva.Grupo != null))
      {
        var emp     = asigActiva.Empleado;
        var miembro = asigActiva.MiembroExterno;
        var grupo   = asigActiva.Grupo;
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
          <div style="width:40px;height:40px;border-radius:50%;background:var(--purple-bg);color:var(--purple-text);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">
            <i class="bi bi-person-fill"></i>
          </div>
          <div>
            @if (emp != null)
            {
              <a asp-controller="Empleados" asp-action="Details" asp-route-id="@emp.Id"
                 style="font-weight:600;font-size:15px;color:var(--accent);text-decoration:none">
                @emp.Nombre
              </a>
              <div class="text-muted">@emp.CodigoEmpleado — @emp.Cargo</div>
            }
            else if (miembro != null)
            {
              <a asp-controller="MiembrosExternos" asp-action="Details" asp-route-id="@miembro.Id"
                 style="font-weight:600;font-size:15px;color:var(--accent);text-decoration:none">
                @miembro.Nombre
              </a>
              <div class="text-muted">@miembro.Organizacion</div>
            }
            else if (grupo != null)
            {
              <a asp-controller="Grupos" asp-action="Details" asp-route-id="@grupo.Id"
                 style="font-weight:600;font-size:15px;color:var(--accent);text-decoration:none">
                @grupo.Nombre
              </a>
            }
          </div>
        </div>
        @if (asigActiva.Equipo != null)
        {
          <div style="margin-bottom:16px;font-size:13px">
            <i class="bi bi-laptop"></i> Entregado junto con
            <a asp-controller="Equipos" asp-action="Details" asp-route-id="@asigActiva.EquipoId"
               style="color:var(--accent);text-decoration:none;font-weight:500">
              @asigActiva.Equipo.NombreEquipo
            </a>
            <span class="text-muted mono" style="font-size:11px">(@asigActiva.Equipo.NumeroSerie)</span>
          </div>
        }
        <div class="form-grid" style="gap:10px">
          <div>
            <div class="form-label">@(emp != null ? "Departamento" : miembro != null ? "Organización" : "Descripción")</div>
            <div style="font-size:13.5px">@(emp?.Departamento?.Nombre ?? miembro?.Organizacion ?? grupo?.Descripcion ?? "—")</div>
          </div>
          <div>
            <div class="form-label">Desde</div>
            <div style="font-size:13.5px">@asigActiva.FechaAsignacion.ToString("dd/MM/yyyy")</div>
          </div>
          <div>
            <div class="form-label">Tipo de movimiento</div>
            <span class="badge @(asigActiva.TipoMovimiento == "Prestamo" ? "badge-prestamo" : "badge-asignado")">
              @(asigActiva.TipoMovimiento == "Prestamo" ? "Préstamo temporal" : "Asignación")
            </span>
            @if (asigActiva.FechaDevolucionEstimada.HasValue)
            {
              <div class="text-muted" style="font-size:12px;margin-top:4px">
                Devolución estimada: @asigActiva.FechaDevolucionEstimada.Value.ToString("dd/MM/yyyy")
              </div>
            }
          </div>
          @if (asigActiva.Sitio != null)
          {
            <div>
              <div class="form-label">Sitio / Ubicación</div>
              <div style="font-size:13.5px"><i class="bi bi-geo-alt"></i> @asigActiva.Sitio.Nombre</div>
            </div>
          }
        </div>
        @if (asigActiva?.Imagenes != null && asigActiva.Imagenes.Any())
        {
          <div style="margin-top:14px;border-top:1px solid #f0f3f8;padding-top:14px">
            <div class="form-label">Registro fotográfico</div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;align-items:center">
              @foreach (var img in asigActiva.Imagenes.Take(4))
              {
                <a href="@img.RutaImagen" target="_blank" title="@(img.Descripcion ?? "Ver foto")"
                   style="display:inline-block;border-radius:6px;overflow:hidden;border:1px solid #dde2ec">
                  <img src="@img.RutaImagen"
                       style="width:64px;height:48px;object-fit:cover;display:block"
                       loading="lazy"
                       onerror="this.closest('a').style.display='none'"/>
                </a>
              }
              @if (asigActiva.Imagenes.Count > 4)
              {
                <span class="text-muted" style="font-size:12px">+@(asigActiva.Imagenes.Count - 4) más</span>
              }
              <a asp-action="PdfHallazgosPeriferico" asp-route-epId="@asigActiva.Id" target="_blank"
                 class="btn btn-secondary btn-sm" style="margin-left:4px">
                <i class="bi bi-file-earmark-pdf"></i> Hallazgos
              </a>
            </div>
          </div>
        }
      }
      else
      {
        <div class="empty-state" style="padding:30px 0">
          <i class="bi bi-check-circle" style="color:var(--green-text);opacity:1"></i>
          <p style="margin-top:8px;color:var(--green-text);font-weight:500">Disponible en stock</p>
          <p style="font-size:12.5px">Este periférico no está asignado a ningún equipo ni empleado.</p>
        </div>
      }
    </div>
  </div>
</div>

@{
  var historial = ViewBag.Historial as List<EquipoPeriferico> ?? new();
}
<div class="card" style="margin-top:20px">
  <div class="card-header">
    <div class="card-title">Historial de asignaciones</div>
    <span class="badge badge-asignado">@((ViewBag.Paginacion as InventarioTI.ViewModels.PaginacionViewModel)?.TotalRegistros ?? 0) registros</span>
  </div>
  @if (historial.Any())
  {
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Asignado a</th>
            <th>Vía equipo</th>
            <th>Desde</th>
            <th>Hasta</th>
            <th>Duración</th>
            <th>Foto</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var ep in historial)
          {
            var esActivo  = !ep.FechaDesvinculacion.HasValue;
            var esDirecto = ep.EquipoId == null;
            var dias      = ep.FechaDesvinculacion.HasValue
              ? (int)(ep.FechaDesvinculacion.Value - ep.FechaAsignacion).TotalDays
              : (int)(DateTime.Today - ep.FechaAsignacion).TotalDays;
            <tr>
              <td>
                @if (esDirecto)
                {
                  <span class="badge badge-asignado">Directo</span>
                }
                else
                {
                  <span class="badge badge-bodega">Vía equipo</span>
                }
              </td>
              <td>
                @if (ep.Empleado != null || ep.MiembroExterno != null || ep.Grupo != null)
                {
                  <div style="font-weight:500;font-size:13px">@ep.NombreResponsable</div>
                  <div class="text-muted">@(ep.Empleado?.CodigoEmpleado ?? ep.MiembroExterno?.Organizacion ?? ep.Grupo?.Descripcion)</div>
                }
                else
                {
                  <span class="text-muted">—</span>
                }
              </td>
              <td>
                @if (ep.Equipo != null)
                {
                  <a asp-controller="Equipos" asp-action="Details" asp-route-id="@ep.EquipoId"
                     style="color:var(--accent);text-decoration:none;font-size:13px">
                    @ep.Equipo.NombreEquipo
                  </a>
                  <div class="mono text-muted" style="font-size:11px">@ep.Equipo.NumeroSerie</div>
                }
                else
                {
                  <span class="text-muted">—</span>
                }
              </td>
              <td class="text-muted">@ep.FechaAsignacion.ToString("dd/MM/yyyy")</td>
              <td>
                @if (esActivo)
                {
                  <span class="badge badge-green">Activo</span>
                }
                else
                {
                  <span class="text-muted">@ep.FechaDesvinculacion!.Value.ToString("dd/MM/yyyy")</span>
                }
              </td>
              <td class="text-muted" style="font-size:12.5px">
                @if (dias == 0)      { <span>Hoy</span> }
                else if (dias == 1)  { <span>1 día</span> }
                else if (dias < 30)  { <span>@dias días</span> }
                else if (dias < 365) { <span>@(dias / 30) mes(es)</span> }
                else                 { <span>@(dias / 365) año(s)</span> }
                @if (esActivo) { <span class="text-muted"> (en curso)</span> }
              </td>
              <td>
                @if (ep.Imagenes != null && ep.Imagenes.Any())
                {
                  <div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap">
                    @foreach (var img in ep.Imagenes.Take(2))
                    {
                      <a href="@img.RutaImagen" target="_blank" title="@(img.Descripcion ?? "Ver foto")"
                         style="display:inline-block;border-radius:6px;overflow:hidden;border:1px solid #dde2ec">
                        <img src="@img.RutaImagen"
                             style="width:52px;height:38px;object-fit:cover;display:block"
                             loading="lazy"
                             onerror="this.closest('a').style.display='none'"/>
                      </a>
                    }
                    <a asp-action="PdfHallazgosPeriferico" asp-route-epId="@ep.Id" target="_blank" title="Hallazgos">
                      <i class="bi bi-file-earmark-pdf"></i>
                    </a>
                  </div>
                }
                else { <span class="text-muted">—</span> }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    <partial name="_Paginacion" model="ViewBag.Paginacion as InventarioTI.ViewModels.PaginacionViewModel"/>
  }
  else
  {
    <div class="card-body">
      <div class="empty-state">
        <i class="bi bi-clock-history"></i> Sin historial de asignaciones.
      </div>
    </div>
  }
</div>


