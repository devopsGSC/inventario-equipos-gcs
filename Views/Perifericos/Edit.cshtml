@model Periferico
@{ ViewData["Title"] = "Editar periférico"; }

<div class="page-header">
  <div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="text-muted" style="text-decoration:none;font-size:13px">
      <i class="bi bi-arrow-left"></i> Detalle
    </a>
    <div class="page-title" style="margin-top:4px">Editar: @Model.Marca @Model.Modelo</div>
  </div>
</div>

<style>
.tipo-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-top:6px; }
.tipo-opt { border:1px solid #dde2ec; border-radius:8px; padding:10px 12px; cursor:pointer; font-size:13px; display:flex; align-items:center; gap:8px; transition:all .15s; background:var(--surface); }
.tipo-opt:hover { border-color:var(--accent); background:var(--blue-bg); }
.tipo-opt.selected { border-color:var(--accent); background:var(--blue-bg); color:var(--blue-text); font-weight:500; }
.nuevo-input-wrap { display:none; margin-top:8px; }
.nuevo-input-wrap.show { display:flex; gap:8px; }
</style>

<div class="card" style="max-width:640px">
  <div class="card-body">
    <form asp-action="Edit" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id"/>
      <input type="hidden" asp-for="Estado"/>
      <input type="hidden" asp-for="FechaRegistro"/>

      <div class="form-group">
        <label class="form-label">Tipo de periférico</label>
        <input type="hidden" asp-for="TipoPerifericoId" id="tipoId"/>
        <div class="tipo-grid" id="tipoGrid">
          @foreach (var t in ((ViewBag.Tipos as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>) ?? []).Where(t => t.Text != "Otro"))
          {
            var icon = t.Text switch {
              "Monitor"         => "bi-display",
              "Headset"         => "bi-headset",
              "Mochila HP"      => "bi-bag",
              "Teclado y Ratón" => "bi-keyboard",
              _                 => "bi-plug"
            };
            var sel = t.Value == Model.TipoPerifericoId.ToString() ? "selected" : "";
            <div class="tipo-opt @sel" data-id="@t.Value" onclick="selTipo(this)">
              <i class="bi @icon"></i> @t.Text
            </div>
          }
          <div class="tipo-opt" data-id="nuevo" onclick="mostrarNuevo()">
            <i class="bi bi-plus-circle"></i> Otro tipo...
          </div>
        </div>
        <div class="nuevo-input-wrap" id="nuevoWrap">
          <input type="text" id="nuevoNombre" class="form-control" placeholder="Nombre del tipo"/>
          <button type="button" class="btn btn-primary btn-sm" onclick="agregarTipo()">Agregar</button>
          <button type="button" class="btn btn-secondary btn-sm" onclick="cancelarNuevo()">Cancelar</button>
        </div>
        <span class="field-error" id="tipoError"></span>
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Marca</label>
          <input asp-for="Marca" class="form-control"/>
          <span asp-validation-for="Marca" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label">Modelo</label>
          <input asp-for="Modelo" class="form-control"/>
          <span asp-validation-for="Modelo" class="field-error"></span>
        </div>
        <div class="form-group span-2">
          <label class="form-label">Número de serie</label>
          <input asp-for="NumeroSerie" class="form-control"/>
          <span asp-validation-for="NumeroSerie" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label">Fecha de compra</label>
          <input asp-for="FechaCompra" class="form-control" type="date"/>
        </div>
        <div class="form-group">
          <label class="form-label">Observaciones (opcional)</label>
          <input type="text" asp-for="Observaciones" class="form-control"/>
        </div>
      </div>

      <div class="gap-2">
        <button type="submit" class="btn btn-primary" onclick="return validar()">
          <i class="bi bi-check-lg"></i> Guardar cambios
        </button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
function selTipo(el) {
  document.querySelectorAll('.tipo-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('tipoId').value = el.dataset.id;
  document.getElementById('nuevoWrap').classList.remove('show');
}
function mostrarNuevo() {
  document.querySelectorAll('.tipo-opt').forEach(o => o.classList.remove('selected'));
  document.querySelector('[data-id="nuevo"]').classList.add('selected');
  document.getElementById('nuevoWrap').classList.add('show');
  document.getElementById('nuevoNombre').focus();
}
function cancelarNuevo() {
  document.getElementById('nuevoWrap').classList.remove('show');
  document.querySelector('[data-id="nuevo"]').classList.remove('selected');
}
async function agregarTipo() {
  const nombre = document.getElementById('nuevoNombre').value.trim();
  if (!nombre) return;
  const res = await fetch('/Perifericos/NuevoTipo', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(nombre)
  });
  const data = await res.json();
  if (!document.querySelector(`[data-id="${data.id}"]`)) {
    const div = document.createElement('div');
    div.className = 'tipo-opt'; div.dataset.id = data.id;
    div.onclick = function() { selTipo(this); };
    div.innerHTML = `<i class="bi bi-plug"></i> ${data.nombre}`;
    document.getElementById('tipoGrid').insertBefore(div, document.querySelector('[data-id="nuevo"]'));
  }
  document.getElementById('tipoId').value = data.id;
  document.getElementById('nuevoWrap').classList.remove('show');
  document.getElementById('nuevoNombre').value = '';
  document.querySelectorAll('.tipo-opt').forEach(o => o.classList.remove('selected'));
  document.querySelector(`[data-id="${data.id}"]`).classList.add('selected');
}
document.getElementById('nuevoNombre').addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); agregarTipo(); }
});
function validar() {
  const v = document.getElementById('tipoId').value;
  if (!v || v === 'nuevo') {
    document.getElementById('tipoError').textContent = 'Seleccione un tipo.';
    return false;
  }
  return true;
}
</script>
