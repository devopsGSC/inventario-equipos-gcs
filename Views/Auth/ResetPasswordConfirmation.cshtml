@{
    Layout = null;
    ViewData["Title"] = "Contraseña actualizada — InventarioTI";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="/gcs_logo.ico"/>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <style>
        :root { --accent: #3b82f6; --dark-text: #1a2540; --dark-text2: #4a5f7a; --surface: #ffffff; --surface2: #f8fafc; --green: #10b981; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'DM Sans', sans-serif; background: var(--surface2); min-height: 100vh; display: flex; align-items: center; justify-content: center; color: var(--dark-text); }
        .card { background: var(--surface); border-radius: 12px; border: 1px solid #e5eaf2; }
        .card-body { padding: 32px; }
        .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; border: none; cursor: pointer; text-decoration: none; }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: #2563eb; }
        .text-muted { color: var(--dark-text2); font-size: 12.5px; }
    </style>
</head>
<body>
<div style="width:100%;max-width:400px;padding:24px">
    <div class="card">
        <div class="card-body" style="padding:32px;text-align:center">
            <div style="font-size:40px;color:var(--green);margin-bottom:12px"><i class="bi bi-check-circle-fill"></i></div>
            <div style="font-size:18px;font-weight:500;margin-bottom:8px">Contraseña actualizada</div>
            <div class="text-muted" style="font-size:13.5px;line-height:1.5;margin-bottom:24px">
                Tu contraseña se cambió correctamente. Ya puedes iniciar sesión con ella.
            </div>
            <a asp-action="Login" asp-controller="Auth" class="btn btn-primary" style="justify-content:center">
                <i class="bi bi-box-arrow-in-right"></i> Iniciar sesión
            </a>
        </div>
    </div>
</div>
</body>
</html>
