@model Grupo
@{ ViewData["Title"] = "Registrar grupo"; }
<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Grupos</a>
    <div class="page-title" style="margin-top:4px">Registrar grupo</div>
  </div>
</div>
<div class="card" style="max-width:640px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div class="form-grid">
        <div class="form-group span-2">
          <label class="form-label" asp-for="Nombre">Nombre del grupo</label>
          <input asp-for="Nombre" class="form-control" placeholder="Ej: Grupo Monitoreo"/>
          <span asp-validation-for="Nombre" class="field-error"></span>
        </div>
        <div class="form-group span-2">
          <label class="form-label" asp-for="Descripcion">Descripción</label>
          <input asp-for="Descripcion" class="form-control" placeholder="Ej: Equipo de monitoreo, sitio San Francisco"/>
        </div>
      </div>
      <div class="gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Registrar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
