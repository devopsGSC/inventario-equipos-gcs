@model Empleado
@{ ViewData["Title"] = Model.Nombre; var equipos = ViewBag.EquiposActuales as List<Movimiento> ?? new List<Movimiento>(); }

<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Empleados</a>
    <div class="page-title" style="margin-top:4px">@Model.Nombre</div>
  </div>
  <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary"><i class="bi bi-pencil"></i> Editar</a>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Datos del empleado</div>
      @if (Model.Activo) { <span class="badge badge-green">Activo</span> }
      else { <span class="badge badge-baja">Inactivo</span> }
    </div>
    <div class="card-body">
      <div class="form-grid" style="gap:14px">
        <div>
          <div class="form-label">Código de empleado</div>
          <div style="font-size:14px;font-weight:500;font-family:'DM Mono',monospace">@Model.CodigoEmpleado</div>
        </div>
        <div>
          <div class="form-label">DUI</div>
          <div style="font-size:14px;font-weight:500">@Model.DUI</div>
        </div>
        <div>
          <div class="form-label">Cargo</div>
          <div style="font-size:14px;font-weight:500">@Model.Cargo</div>
        </div>
        <div>
          <div class="form-label">Departamento</div>
          <div style="font-size:14px;font-weight:500">@(Model.Departamento?.Nombre ?? "—")</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Equipos actuales</div>
      <span class="badge badge-asignado">@equipos.Count en uso</span>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Equipo</th><th>Tipo</th><th>Movimiento</th></tr></thead>
        <tbody>
          @foreach (var m in equipos)
          {
            <tr>
              <td>
                <a asp-controller="Equipos" asp-action="Details" asp-route-id="@m.EquipoId" style="color:var(--accent);text-decoration:none;font-weight:500">@m.Equipo?.NombreEquipo</a>
                <div class="mono text-muted">@m.Equipo?.NumeroSerie</div>
              </td>
              <td>@m.Equipo?.TipoEquipo?.Nombre</td>
              <td>@m.TipoMovimiento<div class="text-muted">@m.FechaInicio.ToString("dd/MM/yyyy")</div></td>
            </tr>
          }
          @if (!equipos.Any())
          {
            <tr><td colspan="3"><div class="empty-state" style="padding:20px"><i class="bi bi-laptop"></i>Sin equipos asignados.</div></td></tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>
