@model Empleado
@{ ViewData["Title"] = "Registrar empleado"; }
<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Empleados</a>
    <div class="page-title" style="margin-top:4px">Registrar empleado</div>
  </div>
</div>
<div class="card" style="max-width:640px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label" asp-for="CodigoEmpleado"></label>
          <input asp-for="CodigoEmpleado" class="form-control" placeholder="Ej: EMP-001"/>
          <span asp-validation-for="CodigoEmpleado" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="DUI"></label>
          <input asp-for="DUI" class="form-control" placeholder="Ej: 00000000-0"/>
          <span asp-validation-for="DUI" class="field-error"></span>
        </div>
        <div class="form-group span-2">
          <label class="form-label" asp-for="Nombre"></label>
          <input asp-for="Nombre" class="form-control" placeholder="Nombre completo"/>
          <span asp-validation-for="Nombre" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="Cargo"></label>
          <input asp-for="Cargo" class="form-control" placeholder="Ej: Analista de TI"/>
          <span asp-validation-for="Cargo" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="DepartamentoId"></label>
          <select asp-for="DepartamentoId" asp-items="ViewBag.Departamentos" class="form-control">
            <option value="">— Seleccionar —</option>
          </select>
          <span asp-validation-for="DepartamentoId" class="field-error"></span>
        </div>
      </div>
      <div class="gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Registrar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
