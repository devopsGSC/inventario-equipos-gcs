@model DashboardViewModel
@{ ViewData["Title"] = "Inventario y gestión de equipos"; }

@{
  var distribucion = new (string Label, int Count, string Color)[]
  {
    ("Bodega",      Model.EnBodega,  "var(--gray)"),
    ("Asignados",   Model.Asignados, "var(--blue)"),
    ("Préstamo",    Model.EnPrestamo,"var(--purple)"),
    ("En garantía", Model.EnGarantia,"var(--amber)"),
    ("Baja",        Model.EnBaja,    "var(--red)"),
  };
}
<div class="card" style="padding:20px;margin-bottom:24px">
  <div style="font-size:34px;font-weight:500;line-height:1;color:var(--dark-text)">@Model.TotalEquipos</div>
  <div class="stat-sub" style="margin-top:4px">equipos en total</div>

  @if (Model.TotalEquipos > 0)
  {
    <div style="display:flex;gap:2px;height:24px;width:100%;border-radius:8px;overflow:hidden;margin-top:16px">
      @foreach (var d in distribucion)
      {
        @if (d.Count > 0)
        {
          <div style="flex-basis:@((d.Count * 100.0 / Model.TotalEquipos).ToString("0.####", System.Globalization.CultureInfo.InvariantCulture))%;background:@d.Color;border-radius:4px"></div>
        }
      }
    </div>

    <div style="display:flex;flex-wrap:wrap;gap:16px;margin-top:12px">
      @foreach (var d in distribucion)
      {
        @if (d.Count > 0)
        {
          <div style="display:flex;align-items:center;gap:6px;font-size:13px">
            <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:@d.Color"></span>
            <span>@d.Label</span>
            <strong>@d.Count</strong>
          </div>
        }
      }
    </div>
  }

  @if (Model.GarantiasProximas > 0 || Model.GarantiasVencidas > 0)
  {
    <div style="border-top:0.5px solid #e5eaf2;padding-top:12px;margin-top:12px">
      @if (Model.GarantiasProximas > 0)
      {
        <a asp-controller="Equipos" asp-action="Index" asp-route-garantiaPorVencer="true"
           style="display:flex;align-items:center;gap:8px;font-size:13px;margin-bottom:6px;color:inherit;text-decoration:none">
          <i class="bi bi-exclamation-triangle-fill" style="color:var(--amber)"></i>
          <span>Garantías por vencer (próximos 30 días)</span>
          <strong>@Model.GarantiasProximas</strong>
        </a>
      }
      @if (Model.GarantiasVencidas > 0)
      {
        <a asp-controller="Equipos" asp-action="Index" asp-route-garantiaVencida="true"
           style="display:flex;align-items:center;gap:8px;font-size:13px;margin-bottom:6px;color:inherit;text-decoration:none">
          <i class="bi bi-x-octagon-fill" style="color:var(--red)"></i>
          <span>Garantías vencidas</span>
          <strong>@Model.GarantiasVencidas</strong>
        </a>
      }
    </div>
  }
</div>

<div class="card" style="margin-bottom:24px">
  <div class="card-header">
    <div class="card-title"><i class="bi bi-search" style="margin-right:6px"></i>Buscar equipo por número de serie</div>
  </div>
  <div class="card-body">
    <form method="get" asp-controller="Home" asp-action="Index">
      <div class="big-search">
        <input type="text" name="serie" class="form-control" placeholder="Ej: 5CD540164K" value="@Model.SerieBuscada"/>
        <button type="submit" class="btn btn-primary">Buscar</button>
      </div>
    </form>

    @if (Model.SerieBuscada != null)
    {
      @if (Model.ResultadoBusqueda == null)
      {
        <div class="alert alert-danger" style="margin-top:16px"><i class="bi bi-x-circle-fill"></i> No se encontró ningún equipo con la serie "@Model.SerieBuscada".</div>
      }
      else
      {
        var eq = Model.ResultadoBusqueda;
        var mov = eq.Movimientos.FirstOrDefault();
        <div class="result-card">
          <div class="rc-name">@eq.NombreEquipo — @eq.Marca @eq.Modelo</div>
          <div class="rc-serie">Serie: @eq.NumeroSerie</div>
          <div class="result-grid">
            <div class="result-field"><label>Tipo</label><p>@eq.TipoEquipo?.Nombre</p></div>
            <div class="result-field"><label>Estado</label><p>@eq.Estado</p></div>
            @if (mov != null && (mov.Empleado != null || mov.MiembroExterno != null || mov.Grupo != null))
            {
              <div class="result-field"><label>Responsable</label><p>@mov.NombreResponsable@(mov.Empleado != null ? $" ({mov.Empleado.CodigoEmpleado})" : "")</p></div>
              <div class="result-field"><label>@(mov.Empleado != null ? "Departamento" : mov.MiembroExterno != null ? "Organización" : "Descripción")</label><p>@(mov.Empleado?.Departamento?.Nombre ?? mov.MiembroExterno?.Organizacion ?? mov.Grupo?.Descripcion ?? "—")</p></div>
              @if (mov.Empleado != null)
              {
                <div class="result-field"><label>Cargo</label><p>@mov.Empleado.Cargo</p></div>
              }
              <div class="result-field"><label>Desde</label><p>@mov.FechaInicio.ToString("dd/MM/yyyy")</p></div>
            }
          </div>
          <div style="margin-top:16px">
            <a asp-controller="Equipos" asp-action="Details" asp-route-id="@eq.Id" class="btn btn-secondary btn-sm">
              <i class="bi bi-arrow-right"></i> Ver detalle completo
            </a>
          </div>
        </div>
      }
    }
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">Últimos equipos registrados</div>
      @if (await PermisoSvc.TienePermiso(User, "equipos.crear"))
      {
        <a asp-controller="Equipos" asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Nuevo</a>
      }
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Equipo</th><th>Tipo</th><th>Estado</th></tr></thead>
        <tbody>
          @foreach (var e in Model.UltimosRegistros)
          {
            <tr>
              <td>
                <a asp-controller="Equipos" asp-action="Details" asp-route-id="@e.Id" style="color:var(--accent);text-decoration:none;font-weight:500">@e.NombreEquipo</a>
                <div class="mono text-muted">@e.NumeroSerie</div>
              </td>
              <td>@e.TipoEquipo?.Nombre</td>
              <td><partial name="_EstadoBadge" model="@e.Estado" /></td>
            </tr>
          }
          @if (!Model.UltimosRegistros.Any())
          { <tr><td colspan="3"><div class="empty-state"><i class="bi bi-inbox"></i>Sin equipos registrados</div></td></tr> }
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><div class="card-title">Últimos movimientos</div></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Equipo</th><th>Movimiento</th><th>Colaborador</th><th>Fecha</th></tr></thead>
        <tbody>
          @foreach (var m in Model.UltimosMovimientos)
          {
            var (badgeCls, badgeLbl) = m.TipoMovimiento switch {
              "Asignacion"      => ("badge-asignado", "Asignación"),
              "Prestamo"        => ("badge-prestamo",  "Préstamo"),
              "Devolucion"      => ("badge-green",     "Devolución"),
              "EntradaGarantia" => ("badge-garantia",  "En garantía"),
              "SalidaGarantia"  => ("badge-green",     "Sale garantía"),
              "Baja"            => ("badge-baja",      "Baja"),
              "Reactivacion"    => ("badge-green",     "Reactivación"),
              _                 => ("badge-bodega",    m.TipoMovimiento)
            };
            <tr>
              <td>
                <a asp-controller="Equipos" asp-action="Details" asp-route-id="@m.EquipoId"
                   style="color:var(--accent);text-decoration:none;font-weight:500">
                  @m.Equipo?.NombreEquipo
                </a>
                <div class="mono text-muted">@m.Equipo?.NumeroSerie</div>
              </td>
              <td><span class="badge @badgeCls">@badgeLbl</span></td>
              <td>
                @if (m.Empleado != null || m.MiembroExterno != null || m.Grupo != null)
                {
                  <div style="font-weight:500;font-size:13px">@m.NombreResponsable</div>
                  <div class="text-muted">@(m.Empleado?.CodigoEmpleado ?? m.MiembroExterno?.Organizacion)</div>
                }
                else { <span class="text-muted">—</span> }
              </td>
              <td class="text-muted">@m.FechaInicio.ToString("dd/MM/yyyy")</td>
            </tr>
          }
          @if (!Model.UltimosMovimientos.Any())
          { <tr><td colspan="4"><div class="empty-state"><i class="bi bi-clock-history"></i>Sin movimientos</div></td></tr> }
        </tbody>
      </table>
    </div>
  </div>
</div>
