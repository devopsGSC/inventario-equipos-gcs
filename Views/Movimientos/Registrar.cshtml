.sitio-opt { border:1px solid #dde2ec; border-radius:8px; padding:10px 12px; cursor:pointer; font-size:13px; display:flex; align-items:center; gap:8px; transition:all .15s; background:var(--surface); }
.sitio-opt:hover { border-color:var(--accent); background:var(--blue-bg); }
.sitio-opt.selected { border-color:var(--accent); background:var(--blue-bg); color:var(--blue-text); font-weight:500; }
.sitio-eliminar { margin-left:auto; font-size:13px; font-weight:600; color:var(--dark-text2); cursor:pointer; padding:0 3px; border-radius:4px; transition:all .15s; }
.sitio-eliminar:hover { background:var(--red-bg, #FEE2E2); color:var(--red-text, #DC2626); }
.nuevo-sitio-wrap { display:none; gap:8px; margin-top:8px; }
.nuevo-sitio-wrap.show { display:flex; }
</style>
