@model MovimientoCreateViewModel
@{
  ViewData["Title"] = "Registrar movimiento";
  var eq = Model.Equipo!;
  bool puedeSeleccionarSitio = await PermisoSvc.TienePermiso(User, "movimientos.sitio");
  bool puedeCrearSitio       = await PermisoSvc.TienePermiso(User, "sitios.crear");
  bool puedeEliminarSitio    = await PermisoSvc.TienePermiso(User, "sitios.eliminar");
}

@{
  var volverControlador = Model.MiembroExternoId.HasValue ? "MiembrosExternos"
                         : Model.GrupoId.HasValue ? "Grupos"
                         : Model.EmpleadoId.HasValue ? "Empleados"
                         : "Equipos";
  var volverId = Model.MiembroExternoId ?? Model.GrupoId ?? Model.EmpleadoId ?? Model.EquipoId;
}

<div class="page-header">
  <div>
    <a asp-controller="@volverControlador" asp-action="Details" asp-route-id="@volverId" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> @eq.NombreEquipo</a>
    <div class="page-title" style="margin-top:4px">Registrar movimiento</div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">
  <div class="card">
    <div class="card-body">
      <form asp-action="Registrar" method="post" id="frmMov">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="EquipoId"/>

        <div class="form-group">
          <label class="form-label">Tipo de movimiento</label>
          @{
            var estadoActual = eq.Estado;
            var tiposDisponibles = estadoActual switch {
              "Bodega"     => new[] { ("Asignacion","Asignación","bi-person-check"), ("Prestamo","Préstamo temporal","bi-arrow-left-right"), ("EntradaGarantia","Entrada a garantía","bi-shield-check"), ("Baja","Dar de baja","bi-x-circle") },
              "Asignado"   => new[] { ("Devolucion","Devolución a bodega","bi-arrow-return-left") },
              "Prestamo"   => new[] { ("Devolucion","Devolución a bodega","bi-arrow-return-left") },
              "EnGarantia" => new[] { ("SalidaGarantia","Salida de garantía","bi-shield-x") },
              _            => Array.Empty<(string,string,string)>()
            };
          }
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px" id="tipo-grid">
            @foreach (var (val, label, icon) in tiposDisponibles)
            {
              <label class="tipo-option" style="border:1px solid #dde2ec;border-radius:10px;padding:14px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:10px">
                <input type="radio" name="TipoMovimiento" value="@val" style="display:none" onchange="onTipo('@val')"/>
                <i class="bi @icon" style="font-size:20px;color:var(--dark-text2)"></i>
                <span style="font-size:13.5px;font-weight:500">@label</span>
              </label>
            }
          </div>
          <span asp-validation-for="TipoMovimiento" class="field-error"></span>
        </div>

        <div id="sec-empleado" style="display:none">
          <div class="form-group">
            <label class="form-label">Responsable</label>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px;margin-bottom:12px" id="responsable-tipo-grid">
              <label class="tipo-option" style="border:1px solid #dde2ec;border-radius:10px;padding:10px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;font-size:12.5px;font-weight:500">
                <input type="radio" name="TipoResponsable" value="Empleado" style="display:none" onchange="onTipoResponsable('Empleado')"/>
                <i class="bi bi-person"></i> Empleado
              </label>
              <label class="tipo-option" style="border:1px solid #dde2ec;border-radius:10px;padding:10px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;font-size:12.5px;font-weight:500">
                <input type="radio" name="TipoResponsable" value="MiembroExterno" style="display:none" onchange="onTipoResponsable('MiembroExterno')"/>
                <i class="bi bi-person-badge"></i> Miembro externo
              </label>
              <label class="tipo-option" style="border:1px solid #dde2ec;border-radius:10px;padding:10px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;font-size:12.5px;font-weight:500">
                <input type="radio" name="TipoResponsable" value="Grupo" style="display:none" onchange="onTipoResponsable('Grupo')"/>
                <i class="bi bi-diagram-3"></i> Grupo
              </label>
            </div>

            <div id="sel-wrap-Empleado">
              <select asp-for="EmpleadoId" class="form-control" id="sel-empleado">
                <option value="">— Seleccionar empleado —</option>
                @foreach (var emp in Model.Empleados)
                {
                  <option value="@emp.Id">@emp.Nombre (@emp.CodigoEmpleado) — @emp.Departamento?.Nombre</option>
                }
              </select>
              <span asp-validation-for="EmpleadoId" class="field-error"></span>
            </div>
            <div id="sel-wrap-MiembroExterno" style="display:none">
              <select asp-for="MiembroExternoId" class="form-control" id="sel-miembroexterno">
                <option value="">— Seleccionar miembro externo —</option>
                @foreach (var m in Model.MiembrosExternos)
                {
                  <option value="@m.Id">@m.Nombre@(string.IsNullOrEmpty(m.Organizacion) ? "" : $" — {m.Organizacion}")</option>
                }
              </select>
            </div>
            <div id="sel-wrap-Grupo" style="display:none">
              <select asp-for="GrupoId" class="form-control" id="sel-grupo">
                <option value="">— Seleccionar grupo —</option>
                @foreach (var g in Model.Grupos)
                {
                  <option value="@g.Id">@g.Nombre</option>
                }
              </select>
            </div>
          </div>
        </div>

        <div id="sec-fechafin" style="display:none">
          <div class="form-group">
            <label class="form-label">Fecha estimada de devolución <span class="text-muted" style="font-weight:400">(opcional)</span></label>
            <input asp-for="FechaFinEstimada" class="form-control" type="date"/>
          </div>
        </div>

        @if (puedeSeleccionarSitio)
        {
          <div id="sec-sitio" style="display:none">
            <div class="form-group">
              <label class="form-label">Sitio / Ubicación física <span class="text-muted" style="font-weight:400">(opcional — solo referencia interna)</span></label>
              <input type="hidden" asp-for="SitioId" id="sitioId"/>
              <div class="sitio-grid" id="sitioGrid">
                @foreach (var s in Model.Sitios)
                {
                  var selSitio = s.Id == Model.SitioId ? "selected" : "";
                  <div class="sitio-opt @selSitio" data-id="@s.Id" data-nombre="@s.Nombre" onclick="seleccionarSitio(this)">
                    <i class="bi bi-geo-alt"></i> <span>@s.Nombre</span>
                    @if (puedeEliminarSitio)
                    {
                      <span class="sitio-eliminar" onclick="event.stopPropagation(); eliminarSitio(@s.Id, this)" title="Eliminar sitio">×</span>
                    }
                  </div>
                }
                @if (puedeCrearSitio)
                {
                  <div class="sitio-opt" data-id="nuevo-sitio" onclick="mostrarNuevoSitio()">
                    <i class="bi bi-plus-circle"></i> Otro sitio...
                  </div>
                }
              </div>
              <div class="nuevo-sitio-wrap" id="nuevoSitioWrap">
                <input type="text" id="nuevoSitioNombre" class="form-control" placeholder="Nombre del sitio"/>
                <button type="button" class="btn btn-primary btn-sm" onclick="agregarNuevoSitio(this)">Agregar</button>
                <button type="button" class="btn btn-secondary btn-sm" onclick="cancelarNuevoSitio()">Cancelar</button>
              </div>
              @if (puedeEliminarSitio)
              {
                <div style="margin-top:8px">
                  <a href="javascript:void(0)" onclick="toggleSitiosInactivos()" style="font-size:12.5px;color:var(--dark-text2)">
                    <i class="bi bi-archive"></i> Sitios desactivados
                  </a>
                  <div id="sitiosInactivosWrap" class="sitio-grid" style="display:none"></div>
                </div>
              }
            </div>
          </div>
        }

        <div class="form-group">
          <label class="form-label">Fecha del movimiento</label>
          <input name="FechaInicio" class="form-control" type="datetime-local" 
                 value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="form-group">
          <label class="form-label" asp-for="Observaciones">Observaciones (opcional)</label>
          <textarea asp-for="Observaciones" class="form-control" rows="2" placeholder="Notas adicionales..."></textarea>
        </div>

        <!-- Firma digital — solo visible para Asignación y Préstamo -->
        <div id="sec-firma" style="display:none">
          <div style="margin:16px 0 8px;font-size:13px;font-weight:600;color:var(--dark-text2);text-transform:uppercase;letter-spacing:.05em">
            Firma del colaborador
          </div>
          <input type="hidden" name="firmaEmpleado" id="firmaInput"/>
          <div style="border:1px solid #dde2ec;border-radius:8px;overflow:hidden;background:#fff;margin-bottom:6px">
            <canvas id="firmaCanvas" style="display:block;width:100%;height:200px;cursor:crosshair;touch-action:none"></canvas>
          </div>
          <div class="gap-2" style="margin-bottom:16px">
            <button type="button" class="btn btn-secondary btn-sm" onclick="limpiarFirma()">
              <i class="bi bi-eraser"></i> Limpiar
            </button>
            <span class="text-muted" style="font-size:12px" id="firmaStatus">Sin firma</span>
          </div>
        </div>

        <!-- Registro fotográfico — solo visible para Asignación, Préstamo y Devolución -->
        <div id="sec-fotos" style="display:none">
          <div style="margin:16px 0 8px;font-size:13px;font-weight:600;color:var(--dark-text2);text-transform:uppercase;letter-spacing:.05em">
            Registro fotográfico <span style="font-weight:400;font-size:11px">(opcional — evidencia del estado)</span>
          </div>

          <div id="dropzoneFotos"
            style="border:2px dashed #dde2ec;border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:12px"
            ondragover="event.preventDefault();this.style.borderColor='var(--accent)';this.style.background='var(--blue-bg)'"
            ondragleave="this.style.borderColor='#dde2ec';this.style.background=''"
            ondrop="handleDropFotos(event)">
            <i class="bi bi-images" style="font-size:32px;color:var(--dark-text2);display:block;margin-bottom:8px"></i>
            <div style="font-size:13.5px;font-weight:500">Arrastra las fotos aquí</div>
            <div class="text-muted" style="font-size:12px;margin-top:4px">o elige una opción:</div>
            <div style="display:flex;gap:8px;justify-content:center;margin-top:12px">
              <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('inputFotos').click()">
                <i class="bi bi-upload"></i> Seleccionar archivos
              </button>
              <button type="button" class="btn btn-secondary btn-sm" onclick="abrirCamaraFotos()">
                <i class="bi bi-camera"></i> Tomar foto
              </button>
            </div>
            <div class="text-muted" style="font-size:11px;margin-top:8px">JPG, PNG, WEBP — máx. 10 MB por foto — sin límite de fotos</div>
          </div>
          <input type="file" id="inputFotos" accept="image/*" multiple style="display:none" onchange="agregarFotosDesdeInput(this)"/>

          <!-- Cámara -->
          <div id="sec-camara-fotos" style="display:none;margin-bottom:12px">
            <div style="background:#000;border-radius:8px;overflow:hidden;margin-bottom:8px;max-height:280px">
              <video id="videoCamaraFotos" autoplay playsinline style="width:100%;display:block;max-height:280px;object-fit:cover"></video>
            </div>
            <canvas id="canvasCamaraFotos" style="display:none"></canvas>
            <div style="display:flex;gap:8px">
              <button type="button" class="btn btn-primary btn-sm" onclick="capturarDesdeCamaraFotos()">
                <i class="bi bi-camera-fill"></i> Capturar foto
              </button>
              <button type="button" class="btn btn-secondary btn-sm" onclick="cerrarCamaraFotos()">
                <i class="bi bi-x"></i> Cerrar cámara
              </button>
            </div>
          </div>

          <!-- Grid de preview de fotos agregadas -->
          <div id="gridFotos" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin-top:8px"></div>
          <div id="contadorFotos" class="text-muted" style="font-size:12px;margin-top:8px"></div>
        </div>

        <!-- Periféricos — solo visible para Asignación y Préstamo -->
        <div id="sec-perifericos" style="display:none">
          <div style="margin:4px 0 8px;font-size:13px;font-weight:600;color:var(--dark-text2);text-transform:uppercase;letter-spacing:.05em">
            Periféricos a entregar
          </div>
          <input type="hidden" name="perifericosIds" id="perifericosIds"/>
          <div id="perifList" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;min-height:38px;padding:8px;border:1px solid #dde2ec;border-radius:8px;background:var(--surface2)">
            <span class="text-muted" id="sinPerifericos" style="font-size:12.5px;align-self:center">Sin periféricos adjuntos</span>
          </div>
          <button type="button" class="btn btn-secondary btn-sm" onclick="abrirModalPerif()">
            <i class="bi bi-plus"></i> Adjuntar periférico
          </button>
          <div class="input-note" style="margin-top:6px">Los periféricos adjuntos quedarán en estado "Asignado" junto con el equipo.</div>
        </div>

        <!-- Modal selector periféricos -->
        <div id="perifModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1000;align-items:center;justify-content:center">
          <div style="background:var(--surface);border-radius:12px;padding:24px;width:500px;max-height:70vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.15)">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
              <div style="font-size:15px;font-weight:600">Seleccionar periférico</div>
              <button type="button" onclick="cerrarModalPerif()" style="background:none;border:none;font-size:22px;cursor:pointer;color:var(--dark-text2)">×</button>
            </div>
            <input type="text" id="buscarPerif" class="form-control" placeholder="Buscar por tipo, marca o serie..." oninput="filtrarPerif()" style="margin-bottom:12px"/>
            <div id="perifOpciones" style="display:flex;flex-direction:column;gap:6px"></div>
          </div>
        </div>

        <div class="gap-2">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Confirmar movimiento</button>
          <a asp-controller="@volverControlador" asp-action="Details" asp-route-id="@volverId" class="btn btn-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><div class="card-title">Equipo</div></div>
    <div class="card-body">
      <div style="margin-bottom:12px"><partial name="_EstadoBadge" model="@eq.Estado" /></div>
      <div style="font-weight:600;font-size:15px;margin-bottom:4px">@eq.NombreEquipo</div>
      <div class="text-muted" style="margin-bottom:14px">@eq.Marca — @eq.Modelo</div>
      <div class="form-label">No. de serie</div>
      <div class="mono" style="margin-bottom:10px">@eq.NumeroSerie</div>
      <div class="form-label">Tipo</div>
      <div style="margin-bottom:10px">@eq.TipoEquipo?.Nombre</div>
      @if (!string.IsNullOrEmpty(eq.Accesorios))
      {
        <div class="form-label">Accesorios</div>
        <div style="font-size:12.5px">@eq.Accesorios</div>
      }
    </div>
  </div>
</div>

<script>
function onTipo(val) {
  document.querySelectorAll('.tipo-option').forEach(el => {
    el.style.borderColor = '#dde2ec';
    el.style.background = '';
  });
  const sel = document.querySelector(`input[value="${val}"]`).closest('.tipo-option');
  sel.style.borderColor = 'var(--accent)';
  sel.style.background = 'var(--blue-bg)';

  const secEmpleado = document.getElementById('sec-empleado');
  secEmpleado.style.display = (val === 'Asignacion' || val === 'Prestamo') ? 'block' : 'none';
  if (secEmpleado.style.display === 'block' && !document.querySelector('input[name="TipoResponsable"]:checked')) {
    const radioEmpleado = document.querySelector('input[name="TipoResponsable"][value="Empleado"]');
    if (radioEmpleado) { radioEmpleado.checked = true; onTipoResponsable('Empleado'); }
  }
  document.getElementById('sec-fechafin').style.display =
    val === 'Prestamo' ? 'block' : 'none';

  // Mostrar firma para Asignacion, Prestamo y Devolucion
  const secFirma = document.getElementById('sec-firma');
  const secPerif = document.getElementById('sec-perifericos');
  const esSalida = (val === 'Asignacion' || val === 'Prestamo');
  secFirma.style.display = (esSalida || val === 'Devolucion') ? 'block' : 'none';
  secPerif.style.display = esSalida ? 'block' : 'none';
  if (secFirma.style.display === 'block') initCanvas();

  document.getElementById('sec-fotos').style.display =
    (val === 'Asignacion' || val === 'Prestamo' || val === 'Devolucion') ? 'block' : 'none';

  const secSitio = document.getElementById('sec-sitio');
  if (secSitio) secSitio.style.display = esSalida || val === 'EntradaGarantia' ? 'block' : 'none';
}

function onTipoResponsable(tipo) {
  document.querySelectorAll('#responsable-tipo-grid .tipo-option').forEach(el => {
    el.style.borderColor = '#dde2ec';
    el.style.background = '';
  });
  const sel = document.querySelector(`input[name="TipoResponsable"][value="${tipo}"]`).closest('.tipo-option');
  sel.style.borderColor = 'var(--accent)';
  sel.style.background = 'var(--blue-bg)';

  document.getElementById('sel-wrap-Empleado').style.display = tipo === 'Empleado' ? 'block' : 'none';
  document.getElementById('sel-wrap-MiembroExterno').style.display = tipo === 'MiembroExterno' ? 'block' : 'none';
  document.getElementById('sel-wrap-Grupo').style.display = tipo === 'Grupo' ? 'block' : 'none';
}

// ── Canvas de firma ──────────────────────────────────
const canvas = document.getElementById('firmaCanvas');
const ctx    = canvas.getContext('2d');
let drawing  = false;
let hasFirma = false;

function initCanvas() {
  const rect = canvas.getBoundingClientRect();
  const dpr  = window.devicePixelRatio || 1;
  canvas.width  = rect.width  * dpr;
  canvas.height = rect.height * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.strokeStyle = '#111';
  ctx.lineWidth   = 2;
  ctx.lineCap     = 'round';
  ctx.lineJoin    = 'round';
}
window.addEventListener('load', initCanvas);
window.addEventListener('resize', initCanvas);

@if (Model.EmpleadoId.HasValue || Model.MiembroExternoId.HasValue || Model.GrupoId.HasValue)
{
  <text>
  window.addEventListener('load', () => {
    const radioAsignacion = document.querySelector('input[name="TipoMovimiento"][value="Asignacion"]');
    if (radioAsignacion) {
      radioAsignacion.checked = true;
      onTipo('Asignacion');
    }
    const radioResponsable = document.querySelector('input[name="TipoResponsable"][value="@Model.TipoResponsable"]');
    if (radioResponsable) {
      radioResponsable.checked = true;
      onTipoResponsable('@Model.TipoResponsable');
    }
  });
  </text>
}

function getPos(e) {
  const rect = canvas.getBoundingClientRect();
  const src  = e.touches ? e.touches[0] : e;
  return { x: src.clientX - rect.left, y: src.clientY - rect.top };
}

canvas.addEventListener('mousedown', e => {
  drawing = true; ctx.beginPath(); const p = getPos(e); ctx.moveTo(p.x, p.y);
});
canvas.addEventListener('mousemove', e => {
  if (!drawing) return;
  const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke();
  hasFirma = true; actualizarStatus();
});
canvas.addEventListener('mouseup',    () => drawing = false);
canvas.addEventListener('mouseleave', () => drawing = false);
canvas.addEventListener('touchstart', e => {
  e.preventDefault(); drawing = true; ctx.beginPath();
  const p = getPos(e); ctx.moveTo(p.x, p.y);
}, { passive: false });
canvas.addEventListener('touchmove', e => {
  e.preventDefault(); if (!drawing) return;
  const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke();
  hasFirma = true; actualizarStatus();
}, { passive: false });
canvas.addEventListener('touchend', () => drawing = false);

function actualizarStatus() {
  const st = document.getElementById('firmaStatus');
  st.textContent = hasFirma ? '✓ Firma capturada' : 'Sin firma';
  st.style.color = hasFirma ? 'var(--green-text)' : '';
}

function limpiarFirma() {
  const rect = canvas.getBoundingClientRect();
  ctx.clearRect(0, 0, rect.width, rect.height);
  hasFirma = false; actualizarStatus();
  document.getElementById('firmaInput').value = '';
}

function prepararFirma() {
  if (hasFirma)
    document.getElementById('firmaInput').value = canvas.toDataURL('image/png');
}

// ── Periféricos ──────────────────────────────────────
let perifs = [], todosPerifs = [];

async function abrirModalPerif() {
  document.getElementById('perifModal').style.display = 'flex';
  if (!todosPerifs.length) {
    const res = await fetch('/Perifericos/Disponibles');
    todosPerifs = await res.json();
  }
  renderOpcionesPerif(todosPerifs);
}
function cerrarModalPerif() { document.getElementById('perifModal').style.display = 'none'; }
function filtrarPerif() {
  const q = document.getElementById('buscarPerif').value.toLowerCase();
  renderOpcionesPerif(todosPerifs.filter(p =>
    p.marca.toLowerCase().includes(q) ||
    p.modelo.toLowerCase().includes(q) ||
    p.numeroSerie.toLowerCase().includes(q) ||
    p.tipo.toLowerCase().includes(q)));
}
function renderOpcionesPerif(lista) {
  const cont = document.getElementById('perifOpciones');
  cont.innerHTML = '';
  const yaIds = perifs.map(p => p.id);
  const disp  = lista.filter(p => !yaIds.includes(p.id));
  if (!disp.length) {
    cont.innerHTML = '<div class="text-muted" style="font-size:13px;padding:10px">No hay periféricos disponibles.</div>';
    return;
  }
  disp.forEach(p => {
    const div = document.createElement('div');
    div.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border:1px solid #dde2ec;border-radius:8px';
    div.innerHTML = `
      <div>
        <div style="font-weight:500;font-size:13.5px">${p.tipo} — ${p.marca} ${p.modelo}</div>
        <div style="font-size:11.5px;color:var(--dark-text2);font-family:monospace">${p.numeroSerie}</div>
      </div>
      <button type="button" class="btn btn-primary btn-sm">Adjuntar</button>`;
    div.querySelector('button').onclick = () => {
      perifs.push(p);
      renderChipsPerif();
      cerrarModalPerif();
    };
    cont.appendChild(div);
  });
}
function quitarPerif(id) {
  perifs = perifs.filter(p => p.id !== id);
  renderChipsPerif();
}
function renderChipsPerif() {
  const cont = document.getElementById('perifList');
  cont.innerHTML = '';
  if (!perifs.length) {
    cont.innerHTML = '<span class="text-muted" style="font-size:12.5px;align-self:center">Sin periféricos adjuntos</span>';
  } else {
    perifs.forEach(p => {
      const chip = document.createElement('span');
      chip.className = 'chip';
      chip.innerHTML = `<i class="bi bi-display" style="font-size:13px"></i> ${p.tipo} — ${p.marca} ${p.modelo} <span class="chip-remove" onclick="quitarPerif(${p.id})">×</span>`;
      cont.appendChild(chip);
    });
  }
  document.getElementById('perifericosIds').value = perifs.map(p => p.id).join(',');
}

// ── Registro fotográfico (múltiples imágenes) ────────
let fotosAgregadas   = []; // Array de { file, previewUrl, descripcion }
let streamCamaraFotos = null;

async function abrirCamaraFotos() {
  document.getElementById('sec-camara-fotos').style.display = 'block';
  if (!streamCamaraFotos) {
    try {
      streamCamaraFotos = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }
      });
      document.getElementById('videoCamaraFotos').srcObject = streamCamaraFotos;
    } catch(e) {
      alert('Cámara no disponible.');
      cerrarCamaraFotos();
    }
  }
}
function cerrarCamaraFotos() {
  document.getElementById('sec-camara-fotos').style.display = 'none';
  if (streamCamaraFotos) { streamCamaraFotos.getTracks().forEach(t => t.stop()); streamCamaraFotos = null; }
}
function capturarDesdeCamaraFotos() {
  const video  = document.getElementById('videoCamaraFotos');
  const canvas = document.getElementById('canvasCamaraFotos');
  canvas.width  = video.videoWidth  || 1280;
  canvas.height = video.videoHeight || 720;
  canvas.getContext('2d').drawImage(video, 0, 0);
  canvas.toBlob(blob => {
    const file = new File([blob], `foto_camara_${Date.now()}.jpg`, { type: 'image/jpeg' });
    agregarFotoMovimiento(file);
  }, 'image/jpeg', 0.88);
}
function agregarFotosDesdeInput(input) {
  Array.from(input.files).forEach(file => agregarFotoMovimiento(file));
  input.value = ''; // reset para permitir seleccionar el mismo archivo de nuevo
}
function handleDropFotos(e) {
  e.preventDefault();
  e.currentTarget.style.borderColor = '#dde2ec';
  e.currentTarget.style.background  = '';
  const files = e.dataTransfer?.files;
  if (files) Array.from(files).forEach(file => {
    if (file.type.startsWith('image/')) agregarFotoMovimiento(file);
  });
}
function agregarFotoMovimiento(file) {
  if (file.size > 10 * 1024 * 1024) { alert(`"${file.name}" supera los 10 MB.`); return; }
  const reader = new FileReader();
  reader.onload = e => {
    fotosAgregadas.push({ file, previewUrl: e.target.result, descripcion: '' });
    renderGridFotos();
  };
  reader.readAsDataURL(file);
}
function quitarFotoMovimiento(idx) {
  fotosAgregadas.splice(idx, 1);
  renderGridFotos();
}
function renderGridFotos() {
  const grid = document.getElementById('gridFotos');
  grid.innerHTML = '';
  fotosAgregadas.forEach((item, idx) => {
    const div = document.createElement('div');
    div.style.cssText = 'position:relative;border-radius:8px;overflow:hidden;border:1px solid #dde2ec;background:#f9fafb';
    div.innerHTML = `
      <img src="${item.previewUrl}" style="width:100%;height:110px;object-fit:cover;display:block"/>
      <div style="padding:6px">
        <input type="text" placeholder="Descripción (opcional)"
               value="${item.descripcion}"
               onchange="fotosAgregadas[${idx}].descripcion=this.value"
               style="width:100%;font-size:11px;border:1px solid #dde2ec;border-radius:4px;padding:3px 6px"/>
      </div>
      <button type="button" onclick="quitarFotoMovimiento(${idx})"
              style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,.55);color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center">×</button>
      <div style="position:absolute;top:4px;left:4px;background:rgba(0,0,0,.55);color:#fff;font-size:11px;padding:1px 6px;border-radius:10px">${idx+1}</div>
    `;
    grid.appendChild(div);
  });
  const count = fotosAgregadas.length;
  document.getElementById('contadorFotos').textContent =
    count === 0 ? '' : `${count} foto${count>1?'s':''} adjunta${count>1?'s':''}`;
}

// Subir fotos después de guardar el movimiento
async function subirFotosMovimiento(movimientoId) {
  if (!fotosAgregadas.length) return;
  const formData = new FormData();
  fotosAgregadas.forEach(item => {
    formData.append('imagenes', item.file);
    formData.append('descripciones', item.descripcion ?? '');
  });
  await fetch(`/Movimientos/SubirImagenes?movimientoId=${movimientoId}`, {
    method: 'POST', body: formData
  });
}

// ── Envío del formulario vía AJAX ─────────────────────
document.getElementById('frmMov').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btnSubmit = this.querySelector('button[type="submit"]');
  setBtnLoading(btnSubmit, true, 'Registrando...');
  prepararFirma();
  const fd = new FormData(this);
  let res;
  try {
    res = await fetch(this.action || window.location.href, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: fd
    });
  } catch (err) {
    setBtnLoading(btnSubmit, false);
    alert('Error de conexión. Intenta de nuevo.');
    return;
  }
  if (!res.ok) {
    setBtnLoading(btnSubmit, false);
    alert('No se pudo registrar el movimiento. Verifica los datos.');
    return;
  }
  const data = await res.json();
  if (data.movimientoId && fotosAgregadas.length) {
    setBtnLoading(btnSubmit, true, 'Subiendo fotos...');
    await subirFotosMovimiento(data.movimientoId);
  }
  cerrarCamaraFotos();
  window.location.href = data.redirectUrl;
});

// ── Sitio / Ubicación ────────────────────────────────
function seleccionarSitio(el) {
  document.querySelectorAll('#sitioGrid .sitio-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('sitioId').value = el.dataset.id;
  document.getElementById('nuevoSitioWrap').classList.remove('show');
}
function mostrarNuevoSitio() {
  document.getElementById('nuevoSitioWrap').classList.add('show');
  document.getElementById('nuevoSitioNombre').focus();
}
function cancelarNuevoSitio() {
  document.getElementById('nuevoSitioWrap').classList.remove('show');
}
async function agregarNuevoSitio(btn) {
  const nombre = document.getElementById('nuevoSitioNombre').value.trim();
  if (!nombre) return;
  setBtnLoading(btn, true, 'Agregando...');
  const res = await fetch('/Movimientos/NuevoSitio', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(nombre)
  });
  setBtnLoading(btn, false);
  if (res.status === 403) { await customAlert('No tienes permiso para crear sitios.', 'danger'); return; }
  if (!res.ok) { await customAlert('No se pudo guardar el sitio. Intenta de nuevo.', 'danger'); return; }
  const data = await res.json();
  if (!document.querySelector(`#sitioGrid [data-id="${data.id}"]`)) {
    const div = document.createElement('div');
    div.className = 'sitio-opt';
    div.dataset.id = data.id;
    div.dataset.nombre = data.nombre;
    div.onclick = function() { seleccionarSitio(this); };
    div.innerHTML = `<i class="bi bi-geo-alt"></i> <span>${data.nombre}</span> <span class="sitio-eliminar" onclick="event.stopPropagation(); eliminarSitio(${data.id}, this)" title="Eliminar sitio">×</span>`;
    document.getElementById('sitioGrid').insertBefore(div, document.querySelector('#sitioGrid [data-id="nuevo-sitio"]'));
  }
  document.getElementById('sitioId').value = data.id;
  document.getElementById('nuevoSitioWrap').classList.remove('show');
  document.getElementById('nuevoSitioNombre').value = '';
  document.querySelectorAll('#sitioGrid .sitio-opt').forEach(o => o.classList.remove('selected'));
  document.querySelector(`#sitioGrid [data-id="${data.id}"]`).classList.add('selected');
}
async function eliminarSitio(id, el) {
  const confirmado = await customConfirm('¿Desactivar este sitio? No se borra su historial y podrás reactivarlo luego desde "Sitios desactivados".', 'warn');
  if (!confirmado) return;
  const original = el.innerHTML;
  el.innerHTML = '<span class="spinner-inline"></span>';
  try {
    const res = await fetch(`/Movimientos/EliminarSitio/${id}`, { method: 'DELETE' });
    if (res.status === 403) { el.innerHTML = original; await customAlert('No tienes permiso para desactivar sitios.', 'danger'); return; }
    if (res.ok) {
      if (document.getElementById('sitioId').value == id) document.getElementById('sitioId').value = '';
      el.closest('.sitio-opt').remove();
    } else {
      el.innerHTML = original;
      await customAlert('No se pudo desactivar: ' + await res.text(), 'danger');
    }
  } catch(e) { el.innerHTML = original; await customAlert('Error de conexión.', 'danger'); }
}
let sitiosInactivosVisibles = false;
async function toggleSitiosInactivos() {
  sitiosInactivosVisibles = !sitiosInactivosVisibles;
  const wrap = document.getElementById('sitiosInactivosWrap');
  wrap.style.display = sitiosInactivosVisibles ? 'grid' : 'none';
  if (sitiosInactivosVisibles) await cargarSitiosInactivos();
}
async function cargarSitiosInactivos() {
  const wrap = document.getElementById('sitiosInactivosWrap');
  wrap.innerHTML = '<span class="text-muted" style="font-size:12.5px">Cargando…</span>';
  const res = await fetch('/Movimientos/ListarSitiosInactivos');
  if (!res.ok) { wrap.innerHTML = '<span class="text-muted" style="font-size:12.5px">No se pudo cargar.</span>'; return; }
  const sitios = await res.json();
  if (sitios.length === 0) { wrap.innerHTML = '<span class="text-muted" style="font-size:12.5px">No hay sitios desactivados.</span>'; return; }
  wrap.innerHTML = '';
  sitios.forEach(s => {
    const div = document.createElement('div');
    div.className = 'sitio-opt';
    div.style.opacity = '.6';
    div.innerHTML = `<i class="bi bi-geo-alt"></i> <span>${s.nombre}</span> <span class="sitio-eliminar" onclick="reactivarSitio(${s.id}, this)" title="Reactivar sitio"><i class="bi bi-arrow-counterclockwise"></i></span>`;
    wrap.appendChild(div);
  });
}
async function reactivarSitio(id, el) {
  const original = el ? el.innerHTML : null;
  if (el) el.innerHTML = '<span class="spinner-inline"></span>';
  const res = await fetch(`/Movimientos/ReactivarSitio/${id}`, { method: 'POST' });
  if (res.status === 403) { if (el) el.innerHTML = original; await customAlert('No tienes permiso para reactivar sitios.', 'danger'); return; }
  if (!res.ok) { if (el) el.innerHTML = original; await customAlert('No se pudo reactivar el sitio.', 'danger'); return; }
  const data = await res.json();
  if (!document.querySelector(`#sitioGrid [data-id="${data.id}"]`)) {
    const div = document.createElement('div');
    div.className = 'sitio-opt';
    div.dataset.id = data.id;
    div.dataset.nombre = data.nombre;
    div.onclick = function() { seleccionarSitio(this); };
    div.innerHTML = `<i class="bi bi-geo-alt"></i> <span>${data.nombre}</span> <span class="sitio-eliminar" onclick="event.stopPropagation(); eliminarSitio(${data.id}, this)" title="Desactivar sitio">×</span>`;
    document.getElementById('sitioGrid').insertBefore(div, document.querySelector('#sitioGrid [data-id="nuevo-sitio"]'));
  }
  await cargarSitiosInactivos();
}
document.getElementById('nuevoSitioNombre')?.addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); agregarNuevoSitio(document.querySelector('#nuevoSitioWrap button.btn-primary')); }
});
</script>

