@model TipoLicencia
@{ ViewData["Title"] = "Registrar tipo de licencia"; }
<div class="page-header">
  <div>
    <a asp-action="Index" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> Licencias</a>
    <div class="page-title" style="margin-top:4px">Registrar tipo de licencia</div>
  </div>
</div>
<div class="card" style="max-width:640px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div class="form-grid">
        <div class="form-group span-2">
          <label class="form-label" asp-for="Nombre">Nombre de la licencia</label>
          <input asp-for="Nombre" class="form-control" placeholder="Ej: Microsoft 365 Empresa Premium"/>
          <span asp-validation-for="Nombre" class="field-error"></span>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="CantidadTotal">Cantidad total <span class="text-muted" style="font-weight:400">(opcional)</span></label>
          <input asp-for="CantidadTotal" class="form-control" type="number" min="0" placeholder="Asientos comprados"/>
        </div>
      </div>
      <div class="gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Registrar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
