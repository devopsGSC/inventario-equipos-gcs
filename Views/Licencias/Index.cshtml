@model List<TipoLicencia>
@{
  ViewData["Title"] = "Licencias";
  var asignadasPorTipo = ViewBag.AsignadasPorTipo as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="page-header">
  <div class="page-title">Licencias</div>
  @if (await PermisoSvc.TienePermiso(User, "licencias.crear"))
  {
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Registrar tipo de licencia</a>
  }
</div>

<div class="card" style="margin-bottom:20px">
  <div class="card-body" style="padding:14px 20px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
      <div class="search-box" style="flex:1;min-width:200px">
        <i class="bi bi-search"></i>
        <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre..." value="@ViewBag.Buscar"/>
      </div>

      <select name="activo" class="form-control" style="width:140px">
        <option value="">Todos los estados</option>
        <option value="true"  selected="@(ViewBag.Activo == true  ? "selected" : null)">Activos</option>
        <option value="false" selected="@(ViewBag.Activo == false ? "selected" : null)">Inactivos</option>
      </select>

      <button type="submit" class="btn btn-secondary">Filtrar</button>
      @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) || ViewBag.Activo != null)
      {
        <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
      }
    </form>
  </div>
</div>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead><tr><th>Nombre</th><th>Asignadas</th><th>Total</th><th>Estado</th><th></th></tr></thead>
      <tbody>
        @foreach (var t in Model)
        {
          var asignadas = asignadasPorTipo.GetValueOrDefault(t.Id);
          <tr>
            <td><a asp-action="Details" asp-route-id="@t.Id" style="color:var(--accent);text-decoration:none;font-weight:500">@t.Nombre</a></td>
            <td>
              <span class="badge badge-asignado">@asignadas asignada@(asignadas == 1 ? "" : "s")</span>
            </td>
            <td>@(t.CantidadTotal?.ToString() ?? "—")</td>
            <td>
              @if (t.Activo) { <span class="badge badge-green">Activo</span> }
              else { <span class="badge badge-baja">Inactivo</span> }
            </td>
            <td>
              <div class="gap-2">
                <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-secondary btn-sm"><i class="bi bi-eye"></i></a>
                @if (await PermisoSvc.TienePermiso(User, "licencias.editar"))
                {
                  <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                }
              </div>
            </td>
          </tr>
        }
        @if (!Model.Any())
        { <tr><td colspan="5"><div class="empty-state"><i class="bi bi-card-checklist"></i>No hay tipos de licencia registrados.</div></td></tr> }
      </tbody>
    </table>
  </div>
</div>
