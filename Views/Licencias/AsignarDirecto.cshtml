@model TipoLicencia
@using InventarioTI.Models
@{ ViewData["Title"] = "Asignar licencia"; }

<div class="page-header">
  <div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="text-muted" style="text-decoration:none;font-size:13px"><i class="bi bi-arrow-left"></i> @Model.Nombre</a>
    <div class="page-title" style="margin-top:4px">Asignar licencia</div>
  </div>
</div>

<div class="card" style="max-width:640px">
  <div class="card-body">
    <form asp-action="AsignarDirecto" asp-route-id="@Model.Id" method="post" id="frmAsignarLicencia">
      @Html.AntiForgeryToken()

      <div class="form-group">
        <label class="form-label">Tipo de responsable</label>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px;margin-bottom:12px" id="responsable-tipo-grid">
          <label class="tipo-option" id="lbl-resp-Empleado" style="border:1px solid #dde2ec;border-radius:10px;padding:10px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;font-size:12.5px;font-weight:500">
            <input type="radio" name="tipoResponsable" value="Empleado" style="display:none" onchange="onTipoResponsable('Empleado')"/>
            <i class="bi bi-person"></i> Empleado
          </label>
          <label class="tipo-option" id="lbl-resp-MiembroExterno" style="border:1px solid #dde2ec;border-radius:10px;padding:10px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;font-size:12.5px;font-weight:500">
            <input type="radio" name="tipoResponsable" value="MiembroExterno" style="display:none" onchange="onTipoResponsable('MiembroExterno')"/>
            <i class="bi bi-person-badge"></i> Miembro externo
          </label>
          <label class="tipo-option" id="lbl-resp-Grupo" style="border:1px solid #dde2ec;border-radius:10px;padding:10px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px;font-size:12.5px;font-weight:500">
            <input type="radio" name="tipoResponsable" value="Grupo" style="display:none" onchange="onTipoResponsable('Grupo')"/>
            <i class="bi bi-diagram-3"></i> Grupo
          </label>
        </div>

        <div id="sel-wrap-Empleado">
          <select name="empleadoId" class="form-control">
            <option value="">— Seleccionar empleado —</option>
            @foreach (var emp in ViewBag.Empleados as List<Empleado> ?? [])
            {
              <option value="@emp.Id">@emp.Nombre (@emp.CodigoEmpleado) — @emp.Departamento?.Nombre</option>
            }
          </select>
        </div>
        <div id="sel-wrap-MiembroExterno" style="display:none">
          <select name="miembroExternoId" class="form-control">
            <option value="">— Seleccionar miembro externo —</option>
            @foreach (var m in ViewBag.MiembrosExternos as List<MiembroExterno> ?? [])
            {
              <option value="@m.Id">@m.Nombre@(string.IsNullOrEmpty(m.Organizacion) ? "" : $" — {m.Organizacion}")</option>
            }
          </select>
        </div>
        <div id="sel-wrap-Grupo" style="display:none">
          <select name="grupoId" class="form-control">
            <option value="">— Seleccionar grupo —</option>
            @foreach (var g in ViewBag.Grupos as List<Grupo> ?? [])
            {
              <option value="@g.Id">@g.Nombre</option>
            }
          </select>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Observaciones <span class="text-muted" style="font-weight:400">(opcional)</span></label>
        <textarea name="observaciones" class="form-control" rows="2" placeholder="Notas adicionales..."></textarea>
      </div>

      <div class="gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Confirmar asignación</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const radio = document.querySelector('#lbl-resp-Empleado input');
  if (radio) radio.checked = true;
  onTipoResponsable('Empleado');
});

function onTipoResponsable(tipo) {
  document.querySelectorAll('#responsable-tipo-grid .tipo-option').forEach(el => {
    el.style.borderColor = '#dde2ec';
    el.style.background = '';
  });
  const lbl = document.getElementById('lbl-resp-' + tipo);
  if (lbl) { lbl.style.borderColor = 'var(--accent)'; lbl.style.background = 'var(--blue-bg)'; }

  document.getElementById('sel-wrap-Empleado').style.display = tipo === 'Empleado' ? 'block' : 'none';
  document.getElementById('sel-wrap-MiembroExterno').style.display = tipo === 'MiembroExterno' ? 'block' : 'none';
  document.getElementById('sel-wrap-Grupo').style.display = tipo === 'Grupo' ? 'block' : 'none';
}
</script>
